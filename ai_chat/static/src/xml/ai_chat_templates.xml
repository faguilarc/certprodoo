<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="AiChatComponent" >
        <div class="o_ai_chat_container d-flex flex-column h-100">

            <!-- Header -->
            <div class="o_ai_chat_header p-3 border-bottom bg-light d-flex align-items-center justify-content-between">
                <h4 class="mb-0 text-secondary">
                    <i class="fa fa-robot me-2"/>AI Chat Assistant
                </h4>
                <button t-if="state.chatId" class="btn btn-sm btn-outline-secondary" t-on-click="onNewChat">
                    <i class="fa fa-plus"/> Nuevo
                </button>
            </div>

            <!-- Messages Area -->
            <div class="o_ai_chat_messages flex-grow-1 p-3 overflow-auto bg-white" t-ref="messagesContainer">
                <t t-if="state.messages.length === 0">
                    <div class="text-center text-muted mt-5">
                        <i class="fa fa-comments fa-3x mb-3"/>
                        <p>¡Hola! 👋 Escribe tu primer mensaje para comenzar.</p>
                    </div>
                </t>
                <t t-else="">
                    <t t-foreach="state.messages" t-as="msg" t-key="msg.id">
                        <div t-class="'o_chat_message o_' + msg.role + '_message' + (msg.isError ? ' o_error_message' : '')">
                            <div class="d-flex align-items-start">
                                <span class="me-2">
                                    <t t-if="msg.role === 'user'">👤</t>
                                    <t t-else="">🤖</t>
                                </span>
                                <div>
                                    <strong><t t-esc="msg.role === 'user' ? 'Tú' : 'IA'"/>:</strong>
                                    <p class="mb-0" t-out="msg.content"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>

                <!-- Thinking Indicator -->
                <t t-if="state.isThinking">
                    <div class="o_chat_message o_ai_message o_thinking">
                        <div class="d-flex align-items-start">
                            <span class="me-2">🤖</span>
                            <div>
                                <strong>IA:</strong>
                                <p class="mb-0">
                                    <span class="spinner-border spinner-border-sm me-1"/>
                                    Escribiendo...
                                </p>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

            <!-- Input Area -->
            <div class="o_ai_chat_input_box d-flex p-3 border-top bg-light">
                <input
                    type="text"
                    class="o_ai_chat_input form-control rounded-pill"
                    placeholder="Escribe tu mensaje aquí..."
                    t-model="state.inputMessage"
                    t-on-keypress="onKeyPress"
                    t-ref="input"
                    autocomplete="off"
                />
                <button
                    class="o_ai_chat_send btn btn-primary ms-2"
                    t-on-click="onSendMessage"
                    t-att-disabled="!state.inputMessage.trim() || state.isThinking"
                >
                    <i class="fa fa-paper-plane"/>
                </button>
            </div>
        </div>
    </t>
</templates>