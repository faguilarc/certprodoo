<odoo>
    <record id="view_ai_provider_form" model="ir.ui.view">
        <field name="name">ai.provider.form</field>
        <field name="model">ai.provider</field>
        <field name="arch" type="xml">
            <form string="AI Provider Configuration">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="provider_type"/>
                        <field name="api_base" placeholder="https://dev.fonse.net:11434"/>
                        <field name="model" placeholder="llama3, mistral, codellama, etc."/>
                        <field name="api_key" attrs="{'invisible': [('provider_type', '=', 'ollama')]}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ai_provider_tree" model="ir.ui.view">
        <field name="name">ai.provider.tree</field>
        <field name="model">ai.provider</field>
        <field name="arch" type="xml">
            <tree string="AI Providers">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="provider_type"/>
                <field name="api_base"/>
                <field name="model"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="action_ai_provider" model="ir.actions.act_window">
        <field name="name">AI Providers</field>
        <field name="res_model">ai.provider</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_ai_config_root" name="AI" sequence="50"/>
    <menuitem id="menu_ai_provider" name="Providers" parent="menu_ai_config_root" action="action_ai_provider" sequence="10"/>
</odoo>