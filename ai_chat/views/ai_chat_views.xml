<!-- ai_chat/views/ai_chat_views.xml -->
<odoo>
    <!-- Esta es la acción que se llamará desde el menú -->
    <record id="action_ai_chat_client" model="ir.actions.client">
        <field name="name">AI Chat</field>
        <field name="tag">ai_chat_wizzard</field>
    </record>

    <!-- El menú para acceder al chat -->
    <menuitem id="menu_ai_chat_main" name="Chat" parent="menu_ai_config_root" action="action_ai_chat_client" sequence="20"/>
</odoo>