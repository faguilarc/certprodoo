<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Regla de registro para que cada usuario vea solo sus solicitudes -->
        <record id="digital_signature_request_user_rule" model="ir.rule">
            <field name="name">Ver solo propias solicitudes (Usuario)</field>
            <field name="model_id" ref="model_digital_signature_request"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
          [                      ('create_uid', '=', user.id)]
            </field>
        </record>

        <!-- Administradores pueden ver todo -->
        <record id="digital_signature_request_manager_rule" model="ir.rule">
            <field name="name">Administradores ven todo</field>
            <field name="model_id" ref="model_digital_signature_request"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>
    </data>
</odoo>