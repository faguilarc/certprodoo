<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- VISTA DE CONFIGURACIÓN (Admin) -->
        <record id="view_digital_signature_config_form" model="ir.ui.view">
            <field name="name">digital.signature.config.form</field>
            <field name="model">digital.signature.config</field>
            <field name="arch" type="xml">
                <form string="Configuración de Firma Digital">
                    <sheet>
                        <div class="oe_title">
                            <h1>Configuración General</h1>
                        </div>
                        <group>
                            <group string="Datos Administrativos">
                                <field name="admin_email"/>
                                <field name="admin_contact"/>
                                <field name="validity_days"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Configuración Nivel Personal">
                                <group>
                                    <field name="conf_show_name"/>
                                    <field name="conf_show_identity"/>
                                    <field name="conf_show_email"/>
                                    <field name="conf_personal_show_profession"/>
                                    <field name="conf_personal_show_specialty"/>
                                </group>
                            </page>
                            <page string="Configuración Nivel Institución">
                                <group>
                                    <field name="conf_show_name"/>
                                    <field name="conf_show_identity"/>
                                    <field name="conf_show_email"/>
                                    <field name="conf_inst_show_profession"/>
                                    <field name="conf_inst_show_specialty"/>
                                    <field name="conf_inst_show_organism"/>
                                    <field name="conf_inst_show_entity"/>
                                    <field name="conf_inst_show_job"/>
                                </group>
                            </page>
                            <page string="Términos y Condiciones">
                                <group>
                                    <field name="terms_html" widget="html"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_digital_signature_config_tree" model="ir.ui.view">
            <field name="name">digital.signature.config.tree</field>
            <field name="model">digital.signature.config</field>
            <field name="arch" type="xml">
                <tree string="Configuraciones de Firma Digital">
                    <!-- Mostramos el email como identificador principal -->
                    <field name="admin_email" string="Correo Administrativo"/>

                    <!-- Datos generales -->
                    <field name="admin_contact" optional="show"/>
                    <field name="validity_days" string="Validez (Días)"/>

                    <!-- Fechas para control de versiones -->
                    <field name="write_date" string="Última Modificación"/>
                </tree>
            </field>
        </record>

        <!-- Action de Configuración -->
        <record id="action_digital_signature_config" model="ir.actions.act_window">
            <field name="name">Configuración Firma Digital</field>
            <field name="res_model">digital.signature.config</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Cree su primera configuración para gestionar las solicitudes de firma digital.
                </p>
            </field>
        </record>

        <!-- Menú -->

        <menuitem id="menu_digital_signature_config" name="Firma Digital"
                  groups="security.group_professional_superadmin"
                  web_icon="digital_signature/static/description/ds_icon.png"
                  sequence="1"/>

        <menuitem id="menu_ds__config" name="Configurar Firma Digital"
                  parent="menu_digital_signature_config"
                  action="action_digital_signature_config"
                  groups="security.group_professional_superadmin"
                  sequence="20"/>


        <!-- VISTA DEL WIZARD (Popup) -->
        <record id="view_digital_signature_wizard_form" model="ir.ui.view">
            <field name="name">digital.signature.wizard.form</field>
            <field name="model">digital.signature.wizard</field>
            <field name="arch" type="xml">
                <form string="Solicitud de Firma Digital">
                    <sheet>
                        <div class="oe_title mb8">
                            <h2 class="text-center">Solicitud de Firma Digital</h2>
                        </div>

                        <!-- Selección de Tipo y Nivel -->
                        <group>
                            <group>
                                <field name="level" widget="radio"/>
                                <field name="request_type" widget="radio"/>
                                <field name="conf_show_name" invisible="1"/>
                                <field name="conf_show_identity" invisible="1"/>
                                <field name="conf_show_email" invisible="1"/>
                                <field name="conf_personal_show_profession" invisible="1"/>
                                <field name="conf_personal_show_specialty" invisible="1"/>
                                <field name="conf_inst_show_profession" invisible="1"/>
                                <field name="conf_inst_show_specialty" invisible="1"/>
                                <field name="conf_inst_show_organism" invisible="1"/>
                                <field name="conf_inst_show_entity" invisible="1"/>
                                <field name="conf_inst_show_job" invisible="1"/>
                            </group>
                            <group></group> <!-- Espaciador -->
                        </group>

                        <!-- Previsualización de Datos (Readonly) -->
                        <notebook>
                            <page string="Resumen de Solicitud">
                                <group>
                                    <!-- Usamos los nuevos campos relacionados en attrs -->
                                    <group string="Datos Personales" >
                                        <field name="disp_name"
                                               attrs="{'invisible': [('conf_show_name', '=', False)]}"/>
                                        <field name="disp_identity"
                                               attrs="{'invisible': [('conf_show_identity', '=', False)]}"/>
                                        <field name="disp_email"
                                               attrs="{'invisible': [('conf_show_email', '=', False)]}"/>
                                    </group>

                                    <!-- Sección Dinámica según Nivel -->
                                    <group string="Detalles Profesionales" >
                                        <group attrs="{'invisible': [('level', '!=', 'personal')]}">
                                            <p class="text-muted">Información para Nivel Personal</p>
                                            <field name="disp_profession"
                                                   attrs="{'invisible': [('conf_personal_show_profession', '=', False)]}"/>
                                            <field name="disp_specialty"
                                                   attrs="{'invisible': [('conf_personal_show_specialty', '=', False)]}"/>
                                        </group>

                                        <group attrs="{'invisible': [('level', '!=', 'institution')]}">
                                            <p class="text-muted">Información para Nivel Institución</p>
                                            <field name="disp_profession"
                                                   attrs="{'invisible': [('conf_inst_show_profession', '=', False)]}"/>
                                            <field name="disp_specialty"
                                                   attrs="{'invisible': [('conf_inst_show_specialty', '=', False)]}"/>
                                            <field name="disp_organism"
                                                   attrs="{'invisible': [('conf_inst_show_organism', '=', False)]}"/>
                                            <field name="disp_entity"
                                                   attrs="{'invisible': [('conf_inst_show_entity', '=', False)]}"/>
                                            <field name="disp_job"
                                                   attrs="{'invisible': [('conf_inst_show_job', '=', False)]}"/>
                                        </group>
                                    </group>
                                </group>
                            </page>

                            <!-- Página de Términos -->
                            <page string="Términos y Condiciones">
                                <group>
                                    <!-- Mostramos los términos usando el campo related -->
                                    <field name="terms_display" readonly="1"/>
<!--                                    <div class="mt-4">-->
<!--                                        <field name="terms_accepted"/>-->
<!--                                        <label for="terms_accepted"-->
<!--                                               string="He leído y acepto los términos y condiciones"/>-->
<!--                                    </div>-->
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="action_send_request" string="Enviar Solicitud" type="object" class="btn-primary"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Acción para abrir el Wizard -->
        <record id="action_open_digital_signature_wizard" model="ir.actions.act_window">
            <field name="name">Solicitud de Firma Digital</field>
            <field name="res_model">digital.signature.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{}</field>
        </record>


        <!-- HERENCIA: Agregar botón en Inscripciones (Tree y Form) -->
        <record id="view_inscription_tree_inherit" model="ir.ui.view">
            <field name="name">professional_registers.inscription.tree.inherit</field>
            <field name="model">professional_registers.inscription</field>
            <field name="inherit_id" ref="professional_registers.inscription_tree_view"/>
            <field name="arch" type="xml">
                <xpath expr="//tree" position="attributes">
                    <attribute name="create">false</attribute>
                </xpath>
                <xpath expr="//tree" position="inside">
                    <button name="%(action_open_digital_signature_wizard)d"
                            string="Solicitar Firma"
                            type="action"

                            icon="fa-certificate"
                            context="{'default_inscription_id': active_id}"/>
                </xpath>
            </field>
        </record>

        <record id="view_inscription_form_inherit" model="ir.ui.view">
            <field name="name">professional_registers.inscription.form.inherit</field>
            <field name="model">professional_registers.inscription</field>
            <field name="inherit_id" ref="professional_registers.inscription_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="before">
                    <header>
                        <button name="%(action_open_digital_signature_wizard)d"
                                string="Solicitar Firma Digital"
                                type="action"
                                class="btn-primary"
                                context="{'default_inscription_id': active_id}"/>
                    </header>
                </xpath>
            </field>
        </record>

                <!-- Vistas para las solicitudes -->
        <record id="view_digital_signature_request_tree" model="ir.ui.view">
            <field name="name">digital.signature.request.tree</field>
            <field name="model">digital.signature.request</field>
            <field name="arch" type="xml">
                <tree string="Solicitudes de Firma Digital">
                    <field name="name" string="Referencia"/>
                    <field name="state" widget="badge" decoration-info="state=='submitted'"
                           decoration-warning="state=='processing'"
                           decoration-success="state=='approved'"
                           decoration-danger="state in ['rejected','expired']"/>
                    <field name="snapshot_name" string="Cliente"/>
                    <field name="snapshot_identity" string="CI"/>
                    <field name="level" string="Nivel"/>
                    <field name="request_type" string="Tipo"/>
                    <field name="request_date" string="Fecha Solicitud"/>
                    <field name="expiry_date" string="Vencimiento"/>
                </tree>
            </field>
        </record>

        <record id="view_digital_signature_request_form" model="ir.ui.view">
            <field name="name">digital.signature.request.form</field>
            <field name="model">digital.signature.request</field>
            <field name="arch" type="xml">
                <form string="Solicitud de Firma Digital">
                    <header>
                        <button name="action_submit" string="Enviar" type="object"
                                class="oe_highlight" states="draft"/>
                        <button name="action_process" string="Procesar" type="object"
                                class="btn-primary" states="submitted"/>
                        <button name="action_approve" string="Aprobar" type="object"
                                class="btn-success" states="processing"/>
                        <button name="action_reject" string="Rechazar" type="object"
                                class="btn-danger" states="submitted,processing"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,submitted,processing,approved,rejected"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>

                        <notebook>
                            <page string="Información General">
                                <group>
                                    <group string="Estado">
                                        <field name="state"/>
                                        <field name="request_date"/>
                                        <field name="expiry_date"/>
                                    </group>
                                    <group string="Configuración">
                                        <field name="config_id"/>
                                        <field name="level"/>
                                        <field name="request_type"/>
                                    </group>
                                </group>

                                <group string="Datos del Solicitante">
                                    <group>
                                        <field name="inscription_id"/>
                                        <field name="snapshot_name"/>
                                        <field name="snapshot_identity"/>
                                        <field name="snapshot_email"/>
                                    </group>
                                    <group>
                                        <field name="snapshot_profession"/>
                                        <field name="snapshot_specialty"/>
                                        % if object.level == 'institution':
                                        <field name="snapshot_organism"/>
                                        <field name="snapshot_entity"/>
                                        <field name="snapshot_job"/>
                                        % endif
                                    </group>
                                </group>
                            </page>

                            <page string="Términos y Condiciones">
                                <field name="terms_html" widget="html" readonly="1"/>
                                <group string="Aceptación">
                                    <field name="terms_accepted" readonly="1"/>
                                    <field name="terms_accepted_date" readonly="1"/>
                                </group>
                            </page>

                            <page string="Administración" groups="base.group_system">
                                <group string="Certificado">
                                    <field name="certificate_number"/>
                                    <field name="certificate_file" filename="certificate_filename"/>
                                    <field name="certificate_filename" invisible="1"/>
                                </group>
                                <group string="Notas">
                                    <field name="admin_notes" widget="textarea" placeholder="Notas internas..."/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>



        <!-- Search View -->
        <record id="view_digital_signature_request_search" model="ir.ui.view">
            <field name="name">digital.signature.request.search</field>
            <field name="model">digital.signature.request</field>
            <field name="arch" type="xml">
                <search string="Buscar Solicitudes">
                    <field name="name"/>
                    <field name="snapshot_name"/>
                    <field name="snapshot_identity"/>
                    <field name="state"/>
                    <field name="level"/>
                    <filter name="state_draft" string="Borrador" domain="[('state','=','draft')]"/>
                    <filter name="state_submitted" string="Enviadas" domain="[('state','=','submitted')]"/>
                    <filter name="state_processing" string="En Proceso" domain="[('state','=','processing')]"/>
                    <filter name="state_approved" string="Aprobadas" domain="[('state','=','approved')]"/>
                    <separator/>
                    <filter name="group_by_level" string="Agrupar por Nivel" context="{'group_by': 'level'}"/>
                    <filter name="group_by_state" string="Agrupar por Estado" context="{'group_by': 'state'}"/>
                </search>
            </field>
        </record>

               <!-- Action para ver solicitudes -->
        <record id="action_digital_signature_requests" model="ir.actions.act_window">
            <field name="name">Solicitudes de Firma Digital</field>
            <field name="res_model">digital.signature.request</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_digital_signature_request_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay solicitudes de firma digital.
                </p>
            </field>
        </record>



        <!-- Menú para solicitudes -->
        <menuitem id="menu_ds_requests" name="Solicitudes"
                  parent="menu_digital_signature_config"
                  action="action_digital_signature_requests"
                  sequence="10"/>

    </data>
</odoo>