<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- VISTA DEL WIZARD (Popup) - CORREGIDA -->
        <record id="view_digital_signature_wizard_form" model="ir.ui.view">
            <field name="name">digital.signature.wizard.form</field>
            <field name="model">digital.signature.wizard</field>
            <field name="arch" type="xml">
                <form string="Solicitud de Firma Digital">
                    <sheet>
                        <div class="oe_title mb8">
                            <h2 class="text-center">Solicitud de Firma Digital</h2>
                        </div>

                        <!-- Selección de Tipo y Nivel -->
                        <group>
                            <field name="level" widget="radio"/>
                            <field name="request_type" widget="radio"/>
                        </group>

                        <!-- Previsualización de Datos (Readonly) -->
                        <notebook>
                            <page string="Resumen de Solicitud">
                                <!-- Datos Personales -->
                                <group string="Datos Personales">
                                    <field name="conf_show_name" invisible="1"></field>
                                    <field name="conf_show_identity" invisible="1"></field>
                                    <field name="conf_show_email" invisible="1"></field>

                                    <field name="disp_name"
                                           attrs="{'invisible': [('conf_show_name', '=', False)]}"/>
                                    <field name="disp_identity"
                                           attrs="{'invisible': [('conf_show_identity', '=', False)]}"/>
                                    <field name="disp_email"
                                           attrs="{'invisible': [('conf_show_email', '=', False)]}"/>
                                </group>

                                <!-- Sección Dinámica según Nivel -->
                                <group string="Detalles Profesionales">
                                    <!-- Nivel Personal -->
                                    <group attrs="{'invisible': [('level', '!=', 'personal')]}"
                                           string="Nivel Personal">
                                        <field name="conf_personal_show_profession" invisible="1"></field>
                                        <field name="conf_personal_show_specialty" invisible="1"></field>

                                        <field name="disp_profession"
                                               attrs="{'invisible': [('conf_personal_show_profession', '=', False)]}"/>
                                        <field name="disp_specialty"
                                               attrs="{'invisible': [('conf_personal_show_specialty', '=', False)]}"/>
                                    </group>

                                    <!-- Nivel Institución -->
                                    <group attrs="{'invisible': [('level', '!=', 'institution')]}"
                                           string="Nivel Institución">
                                        <field name="conf_inst_show_profession" invisible="1"></field>
                                        <field name="conf_inst_show_specialty" invisible="1"></field>
                                        <field name="conf_inst_show_organism" invisible="1"></field>
                                        <field name="conf_inst_show_entity" invisible="1"></field>
                                        <field name="conf_inst_show_job" invisible="1"></field>

                                        <field name="disp_profession"
                                               attrs="{'invisible': [('conf_inst_show_profession', '=', False)]}"/>
                                        <field name="disp_specialty"
                                               attrs="{'invisible': [('conf_inst_show_specialty', '=', False)]}"/>
                                        <field name="disp_organism"
                                               attrs="{'invisible': [('conf_inst_show_organism', '=', False)]}"/>
                                        <field name="disp_entity"
                                               attrs="{'invisible': [('conf_inst_show_entity', '=', False)]}"/>
                                        <field name="disp_job"
                                               attrs="{'invisible': [('conf_inst_show_job', '=', False)]}"/>
                                    </group>
                                </group>
                            </page>

                            <!-- Página de Términos -->
                            <page string="Términos y Condiciones">
                                <div class="alert alert-info">
                                    <i class="fa fa-exclamation-triangle mr-2"></i>
                                    Lea cuidadosamente los términos y condiciones antes de aceptar.
                                </div>

                                <field name="terms_display" readonly="1"/>

                                <div class="mt-4">
                                    <field name="terms_accepted"/>
                                    <label for="terms_accepted"
                                           string="He leído y acepto los términos y condiciones"/>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="action_send_request" string="Enviar Solicitud" type="object"
                                class="btn-primary" attrs="{'invisible': [('terms_accepted', '=', False)]}"/>
                        <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Acción para abrir el Wizard -->
        <record id="action_open_digital_signature_wizard" model="ir.actions.act_window">
            <field name="name">Solicitud de Firma Digital</field>
            <field name="res_model">digital.signature.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_inscription_id': active_id}</field>
        </record>
    </data>
</odoo>