<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Secuencia para solicitudes -->
        <record id="seq_digital_signature_request" model="ir.sequence">
            <field name="name">Solicitud de Firma Digital</field>
            <field name="code">digital.signature.request</field>
            <field name="prefix">Firma-%(y)s-%(month)s-</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Configuración por defecto -->
        <record id="digital_signature_config_default" model="digital.signature.config">
            <field name="admin_email">admin@empresa.com</field>
            <field name="admin_contact">Administrador del Sistema</field>
            <field name="validity_days">30</field>
            <field name="active">True</field>
            <field name="terms_html">
                <![CDATA[
                <div style="font-family: Arial, sans-serif;">
                    <h3>Términos y Condiciones para Firma Digital</h3>
                    <p>Al solicitar la firma digital, usted acepta:</p>
                    <ol>
                        <li>Utilizar la firma digital únicamente para los fines autorizados.</li>
                        <li>Mantener la confidencialidad de sus credenciales de acceso.</li>
                        <li>Notificar inmediatamente cualquier uso no autorizado.</li>
                        <li>Cumplir con la legislación vigente sobre firma digital.</li>
                    </ol>
                    <p><strong>Validez:</strong> 30 días desde la aprobación.</p>
                    <p><strong>Responsabilidad:</strong> El usuario es responsable del uso que se dé a su firma digital.</p>
                </div>
                ]]>
            </field>
        </record>
    </data>
</odoo>