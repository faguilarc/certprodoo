<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de formulario para pruebas de FUC -->
    <record id="view_fuc_test_form" model="ir.ui.view">
        <field name="name">fuc.test.form</field>
        <field name="model">fuc.test</field>
        <field name="arch" type="xml">
            <form string="Pruebas de Conexión a FUC">
                <sheet>
                    <group>
                        <group>
                            <field name="identity_number"/>
                            <field name="use_simulation"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Resultados">
                            <field name="test_result" readonly="1" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_test_connection" type="object" string="Probar Conexión" class="btn-primary"/>
                    <button name="action_generate_token" type="object" string="Generar Token" class="btn-secondary"/>
                    <button special="cancel" string="Cerrar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción para pruebas de FUC -->
    <record id="action_fuc_test" model="ir.actions.act_window">
        <field name="name">Pruebas de Conexión a FUC</field>
        <field name="res_model">fuc.test</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Realiza pruebas de conexión a la API de FUC
            </p>
            <p>
                Ingresa un número de identidad para probar la conexión y ver los resultados.
            </p>
        </field>
    </record>

    <!-- Menú para pruebas de FUC -->
    <menuitem id="menu_fuc_test"
              name="Pruebas de Conexión"
              parent="menu_fuc_config_root"
              action="action_fuc_test"
              sequence="20"/>
</odoo>