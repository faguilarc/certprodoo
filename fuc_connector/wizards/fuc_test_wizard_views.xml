<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de formulario para el asistente de prueba -->
    <record id="view_fuc_test_wizard_form" model="ir.ui.view">
        <field name="name">fuc.test.wizard.form</field>
        <field name="model">fuc.test.wizard</field>
        <field name="arch" type="xml">
            <form string="Probar Conexión">
                <sheet>
                    <group>
                        <field name="identity_number"/>
                        <field name="use_simulation"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_test" type="object" string="Probar" class="btn-primary"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Vista de formulario para el asistente de resultado -->
    <record id="view_fuc_result_wizard_form" model="ir.ui.view">
        <field name="name">fuc.result.wizard.form</field>
        <field name="model">fuc.result.wizard</field>
        <field name="arch" type="xml">
            <form string="Resultado de la Prueba">
                <sheet>
                    <field name="message" readonly="1"/>
                </sheet>
                <footer>
                    <button special="cancel" string="Cerrar" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>