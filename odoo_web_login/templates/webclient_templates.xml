<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="assets_login1" inherit_id="web.assets_frontend">
        <xpath expr="." position="inside">
            <link rel="stylesheet" href="/odoo_web_login/static/src/css/web_login_style.css"/>
        </xpath>
    </template>

    <template id="login_layout" inherit_id="web.login_layout" name="Login Layout Inherit">
        <xpath expr="//t[@t-set='body_classname']" position="after">
            <t t-set="body_classname" t-value="''"/>
        </xpath>

        <xpath expr="//div[hasclass('container')]" position="attributes">
            <attribute name="class">body_login</attribute>
        </xpath>

        <xpath expr="//div[@t-attf-class='card border-0 mx-auto bg-100 {{login_card_classes}} o_database_list']"
               position="before">
            <div id="background-wrapper" t-attf-style="background-image: url('#{background_src}');"></div>
        </xpath>


        <xpath expr="//div[@t-attf-class='card border-0 mx-auto bg-100 {{login_card_classes}} o_database_list']"
               position="attributes">
            <attribute name="class">glass-card col-lg-3 col-md-4 col-sm-4 col-xs-11 o_database_list</attribute>
            <attribute name="style">background: rgba(199,199,199,0.5);
                border-radius: 10px;
                -webkit-backdrop-filter: blur(10px);
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255,255,255,0.25);
            </attribute>
        </xpath>

        <xpath expr="//div[hasclass('card-body')]/div/img[1]" position="attributes">
            <attribute name="class">company_logo</attribute>
        </xpath>
        <xpath expr="//div[@t-attf-class='card border-0 mx-auto bg-100 {{login_card_classes}} o_database_list']/div[1]/div[2]"
               position="replace"/>

    </template>

    <template id="login" inherit_id="web.login" name="Login Inherit">
        <xpath expr="//label[@for='db']" position="replace"/>
        <xpath expr="//label[@for='login']" position="replace"/>
        <xpath expr="//label[@for='password']" position="replace"/>
        <xpath expr="//button[@name='redirect']" position="replace"/>

        <xpath expr="//input[@name='login']" position="attributes">
            <attribute name="placeholder">Usuario ...</attribute>
            <attribute name="autocorrect">off</attribute>
        </xpath>

        <xpath expr="//input[@name='password']" position="attributes">
            <attribute name="placeholder">Contraseña ...</attribute>
        </xpath>

        <xpath expr="//a[@href='/web/database/selector']" position="replace"/>
        <xpath expr="//input[@name='db']" position="replace"/>
    </template>


</odoo>
