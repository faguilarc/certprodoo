<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- NOTA: Las secuencias específicas se definen en cada módulo
         de negocio. El módulo base solo proporciona la infraestructura
         (SequenceMixin + SequenceTemplate). -->

    <!-- Cron job para verificar timers de auto-transición -->
    <record id="state_timer_cron" model="ir.cron">
        <field name="name">CertProdoo: Verificar Timers de Estado</field>
        <field name="model_id" ref="model_certprodoo_base_state_timer"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_timers()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="priority">10</field>
    </record>
</odoo>
