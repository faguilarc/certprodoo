<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menú principal del módulo base -->
    <menuitem id="menu_certprodoo_root"
              name="CertProdoo"
              web_icon="certprodoo_base,static/description/icon.png"
              sequence="10"/>

    <!-- Submenú de Configuración -->
    <menuitem id="menu_certprodoo_config"
              name="Configuración"
              parent="menu_certprodoo_root"
              sequence="100"/>

    <!-- Menú de APIs -->
    <menuitem id="menu_api_config"
              name="APIs Externas"
              parent="menu_certprodoo_config"
              action="api_config_action"
              sequence="10"/>

    <!-- Menú de Parámetros del Sistema -->
    <menuitem id="menu_system_config"
              name="Parámetros del Sistema"
              parent="menu_certprodoo_config"
              action="system_config_action"
              sequence="20"/>

