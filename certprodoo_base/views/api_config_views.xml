<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de Formulario de Configuración de API -->
    <record id="api_config_view_form" model="ir.ui.view">
        <field name="name">certprodoo.base.api.config.form</field>
        <field name="model">certprodoo.base.api.config</field>
        <field name="arch" type="xml">
            <form string="Configuración de API">
                <header>
                    <button name="action_test_connection" string="Probar Conexión" type="object"
                            class="btn-primary" icon="fa-plug"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Inactiva" bg_color="bg-danger"
                            invisible="active == True"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre de la configuración"/></h1>
                    </div>
                    <group>
                        <group string="Tipo de API">
                            <field name="api_type"/>
                            <field name="auth_type"/>
                            <field name="active"/>
                        </group>
                        <group string="Credenciales">
                            <field name="key_1" password="True"/>
                            <field name="key_2" password="True"/>
                        </group>
                    </group>
                    <group>
                        <group string="URLs">
                            <field name="url" placeholder="https://api.ejemplo.com/token"/>
                            <field name="url_base" placeholder="https://api.ejemplo.com/consultas?"/>
                        </group>
                        <group string="Autenticación OAuth2">
                            <field name="scope"/>
                            <field name="grant_type"/>
                        </group>
                    </group>
                    <group string="Configuración de Reintentos">
                        <group>
                            <field name="max_retries"/>
                            <field name="retry_delay"/>
                        </group>
                        <group>
                            <field name="request_timeout"/>
                            <field name="use_simulation"/>
                        </group>
                    </group>
                    <group string="Información de Token">
                        <group>
                            <field name="token" readonly="1"/>
                            <field name="token_expiry" readonly="1"/>
                        </group>
                        <group>
                            <field name="last_test" readonly="1"/>
                            <field name="last_test_result" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista de Lista de Configuración de API -->
    <record id="api_config_view_tree" model="ir.ui.view">
        <field name="name">certprodoo.base.api.config.tree</field>
        <field name="model">certprodoo.base.api.config</field>
        <field name="arch" type="xml">
            <tree string="Configuraciones de API">
                <field name="name"/>
                <field name="api_type"/>
                <field name="url"/>
                <field name="active"/>
                <field name="last_test"/>
            </tree>
        </field>
    </record>

    <!-- Acción de Configuración de API -->
    <record id="api_config_action" model="ir.actions.act_window">
        <field name="name">Configuración de APIs</field>
        <field name="res_model">certprodoo.base.api.config</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure las APIs externas del sistema
            </p>
        </field>
    </record>
</odoo>
