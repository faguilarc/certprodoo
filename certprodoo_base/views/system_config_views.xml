<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de Formulario de Parámetros del Sistema -->
    <record id="system_config_view_form" model="ir.ui.view">
        <field name="name">certprodoo.base.system.config.form</field>
        <field name="model">certprodoo.base.system.config</field>
        <field name="arch" type="xml">
            <form string="Parámetro del Sistema">
                <group>
                    <group>
                        <field name="key"/>
                        <field name="value"/>
                    </group>
                    <group>
                        <field name="description"/>
                        <field name="module"/>
                        <field name="is_readonly"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- Vista de Lista de Parámetros del Sistema -->
    <record id="system_config_view_tree" model="ir.ui.view">
        <field name="name">certprodoo.base.system.config.tree</field>
        <field name="model">certprodoo.base.system.config</field>
        <field name="arch" type="xml">
            <tree string="Parámetros del Sistema" editable="bottom">
                <field name="key"/>
                <field name="value"/>
                <field name="description"/>
                <field name="module"/>
                <field name="is_readonly"/>
            </tree>
        </field>
    </record>

    <!-- Acción de Parámetros del Sistema -->
    <record id="system_config_action" model="ir.actions.act_window">
        <field name="name">Parámetros del Sistema</field>
        <field name="res_model">certprodoo.base.system.config</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure los parámetros globales del sistema
            </p>
        </field>
    </record>
</odoo>
