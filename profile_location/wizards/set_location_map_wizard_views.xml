<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_set_location_map_wizard_form" model="ir.ui.view">
        <field name="name">set.location.map.wizard.form</field>
        <field name="model">set.location.map.wizard</field>
        <field name="arch" type="xml">
            <form string="Establecer Ubicación en Mapa">
                <sheet>
                    <group>
                        <group>
                            <field name="profile_id" invisible="1"/>
                            <field name="project_id" invisible="1"/>
                            <field name="current_latitude" readonly="1"/>
                            <field name="current_longitude" readonly="1"/>
                        </group>
                        <group>
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                    </group>

                    <div class="row">
                        <div class="col-12">
                            <div id="map" style="height: 400px; width: 100%;"></div>
                        </div>
                    </div>

                    <script>
                        $(document).ready(function() {
                            // Inicializar el mapa
                            var map = L.map('map').setView([23.1136, -82.3666], 13);

                            // Añadir capa de OpenStreetMap
                            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                attribution: '© OpenStreetMap contributors'
                            }).addTo(map);

                            // Marcador inicial
                            var marker = L.marker([parseFloat($('[name="current_latitude"]').val()),
                                                     parseFloat($('[name="current_longitude"]').val())])
                                .addTo(map)
                                .bindPopup('Ubicación actual');

                            // Evento de clic en el mapa
                            map.on('click', function(e) {
                                // Actualizar los campos del formulario
                                $('[name="latitude"]').val(e.latlng.lat.toFixed(6));
                                $('[name="longitude"]').val(e.latlng.lng.toFixed(6));

                                // Mover el marcador
                                marker.setLatLng(e.latlng);
                            });
                        });
                    </script>
                </sheet>
                <footer>
                    <button name="action_save_location" type="object" string="Guardar Ubicación" class="btn-primary"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>