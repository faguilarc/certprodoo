<!-- wizards/find_professionals_by_location_views.xml (modificación) -->
<record id="view_find_professionals_by_location_form" model="ir.ui.view">
    <field name="name">find.professionals.by.location.form</field>
    <field name="model">find.professionals.by.location</field>
    <field name="arch" type="xml">
        <form string="Buscar Profesionales por Ubicación">
            <sheet>
                <group>
                    <group>
                        <field name="project_id"/>
                        <field name="max_distance"/>
                    </group>
                    <group>
                        <field name="profession_id"/>
                        <field name="specialty_id"/>
                    </group>
                    <group>
                        <field name="state_id"/>
                    </group>
                </group>

                <notebook>
                    <page string="Profesionales Disponibles">
                        <field name="available_professionals">
                            <tree>
                                <field name="name"/>
                                <field name="profession"/>
                                <field name="specialties"/>
                                <field name="state_id"/>
                                <field name="distance"/>
                                <field name="selected"/>
                            </tree>
                        </field>
                    </page>

                    <page string="Mapa">
                        <div class="row">
                            <div class="col-12">
                                <div id="map" style="height: 400px;"></div>
                            </div>
                        </div>
                        <script>
                            $(document).ready(function() {
                                // Inicializar el mapa
                                var map = L.map('map').setView(
                                    [parseFloat($('[name="project_latitude"]').val()),
                                     parseFloat($('[name="project_longitude"]').val())], 12
                                );

                                // Añadir capa de OpenStreetMap
                                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                                    attribution: '© OpenStreetMap contributors'
                                }).addTo(map);

                                // Marcador para el proyecto
                                var projectMarker = L.marker([
                                    parseFloat($('[name="project_latitude"]').val()),
                                    parseFloat($('[name="project_longitude"]').val())
                                ]).addTo(map).bindPopup('Proyecto').openPopup();

                                // Marcadores para los profesionales
                                $('.o_list_view tbody tr').each(function() {
                                    var row = $(this);
                                    var lat = row.find('td[data-field="latitude"]').text();
                                    var lng = row.find('td[data-field="longitude"]').text();
                                    var name = row.find('td[data-field="name"]').text();
                                    var distance = row.find('td[data-field="distance"]').text();

                                    if (lat &amp;&amp; lng) {
                                        var marker = L.marker([parseFloat(lat), parseFloat(lng)])
                                            .addTo(map)
                                            .bindPopup(name + ' - ' + distance + ' km');
                                    }
                                });
                            });
                        </script>
                    </page>
                </notebook>
            </sheet>
            <footer>
                <button name="action_assign_professionals" type="object"
                        string="Asignar Seleccionados" class="btn-primary"/>
                <button name="action_show_on_map" type="object"
                        string="Ver en Mapa" class="btn-secondary"/>
                <button special="cancel" string="Cancelar" class="btn-secondary"/>
            </footer>
        </form>
    </field>
</record>