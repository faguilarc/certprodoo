<record id="view_profile_form_inherit_location" model="ir.ui.view">
    <field name="name">professional.registers.profile.form.inherit.location</field>
    <field name="model">professional_registers.profile</field>
    <field name="inherit_id" ref="professional_registers.view_profile_form"/>
    <field name="arch" type="xml">
        <xpath expr="//notebook" position="inside">
            <page string="Ubicación">
                    <group>
                        <group>
                            <field name="street"/>
                            <field name="street2"/>
                            <field name="zip"/>
                        </group>
                        <group>
                            <field name="city"/>
                            <field name="state_id"/>
                            <field name="country_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="latitude"/>
                            <field name="longitude"/>
                        </group>
                        <group>
                            <field name="has_coordinates" readonly="1"/>
                            <button name="action_set_location_from_map" type="object"
                                    string="Establecer en Mapa" class="btn-primary"/>
                        </group>
                    </group>
                </page>
        </xpath>
    </field>
</record>