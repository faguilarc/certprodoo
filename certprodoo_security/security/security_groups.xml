<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════ -->
    <!-- CATEGORÍAS DE SEGURIDAD                                    -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Categoría Permisos -->
    <record id="module_category_certprodoo_permissions" model="ir.module.category">
        <field name="name">CertProdoo Permisos</field>
        <field name="description">Permisos de acceso al sistema de seguridad</field>
        <field name="parent_id" ref="certprodoo_base.module_category_certprodoo"/>
        <field name="sequence">10</field>
    </record>

    <!-- Grupo de acceso a permisos -->
    <record id="group_certprodoo_permissions_access" model="res.groups">
        <field name="name">Permisos de Acceso</field>
        <field name="category_id" ref="module_category_certprodoo_permissions"/>
        <field name="implied_ids" eval="[(4, ref('certprodoo_base.group_certprodoo_admin'))]"/>
        <field name="comment">Acceso al módulo de permisos y seguridad</field>
    </record>

    <!-- Categoría Roles de Registro Profesional -->
    <record id="module_category_certprodoo_professional_roles" model="ir.module.category">
        <field name="name">CertProdoo Roles Profesionales</field>
        <field name="description">Roles de usuarios para gestión de registros profesionales</field>
        <field name="parent_id" ref="certprodoo_base.module_category_certprodoo"/>
        <field name="sequence">20</field>
    </record>

    <!-- ─── Roles de Registro Profesional ─────────────────────── -->

    <record id="group_professional_register_employee" model="res.groups">
        <field name="name">Registrador</field>
        <field name="category_id" ref="module_category_certprodoo_professional_roles"/>
        <field name="implied_ids" eval="[(4, ref('certprodoo_base.group_certprodoo_user'))]"/>
    </record>

    <record id="group_professional_editor" model="res.groups">
        <field name="name">Editor</field>
        <field name="category_id" ref="module_category_certprodoo_professional_roles"/>
        <field name="implied_ids" eval="[(4, ref('group_professional_register_employee'))]"/>
    </record>

    <record id="group_professional_management" model="res.groups">
        <field name="name">Gestor</field>
        <field name="category_id" ref="module_category_certprodoo_professional_roles"/>
        <field name="implied_ids" eval="[(4, ref('group_professional_register_employee'))]"/>
    </record>

    <record id="group_professional_consultant" model="res.groups">
        <field name="name">Consultor</field>
        <field name="category_id" ref="module_category_certprodoo_professional_roles"/>
        <field name="implied_ids" eval="[(4, ref('certprodoo_base.group_certprodoo_user'))]"/>
    </record>

    <record id="group_professional_client" model="res.groups">
        <field name="name">Cliente</field>
        <field name="category_id" ref="module_category_certprodoo_professional_roles"/>
        <field name="implied_ids" eval="[(4, ref('certprodoo_base.group_certprodoo_portal'))]"/>
    </record>

    <record id="group_professional_client_online" model="res.groups">
        <field name="name">Cliente Online</field>
        <field name="category_id" ref="module_category_certprodoo_professional_roles"/>
        <field name="implied_ids" eval="[(4, ref('certprodoo_base.group_certprodoo_portal'))]"/>
    </record>

    <!-- ─── Roles Combinados ──────────────────────────────────── -->

    <record id="group_professional_register_management" model="res.groups">
        <field name="name">Registrador / Gestor</field>
        <field name="category_id" ref="module_category_certprodoo_professional_roles"/>
        <field name="implied_ids" eval="[(4, ref('group_professional_register_employee')), (4, ref('group_professional_management'))]"/>
    </record>

    <record id="group_professional_editor_management" model="res.groups">
        <field name="name">Editor / Gestor</field>
        <field name="category_id" ref="module_category_certprodoo_professional_roles"/>
        <field name="implied_ids" eval="[(4, ref('group_professional_editor')), (4, ref('group_professional_management'))]"/>
    </record>

    <record id="group_professional_superadmin" model="res.groups">
        <field name="name">Superadmin</field>
        <field name="category_id" ref="module_category_certprodoo_professional_roles"/>
        <field name="implied_ids" eval="[(4, ref('group_professional_editor')), (4, ref('group_professional_management')), (4, ref('base.group_erp_manager'))]"/>
    </record>
</odoo>
