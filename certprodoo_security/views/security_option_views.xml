<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de Lista de Opciones -->
    <record id="security_option_view_tree" model="ir.ui.view">
        <field name="name">certprodoo.security.option.tree</field>
        <field name="model">certprodoo.security.option</field>
        <field name="arch" type="xml">
            <tree string="Opciones de Seguridad" editable="bottom">
                <field name="name"/>
                <field name="model_id"/>
                <field name="model_name"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- Acción de Opciones -->
    <record id="security_option_action" model="ir.actions.act_window">
        <field name="name">Opciones</field>
        <field name="res_model">certprodoo.security.option</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure las opciones securizables del sistema
            </p>
        </field>
    </record>
</odoo>
