<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Herencia de vista de formulario de compañía -->
    <record id="res_company_view_form_inherit" model="ir.ui.view">
        <field name="name">res.company.form.inherit.certprodoo.security</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='social_media']" position="after">
                <group name="certprodoo" string="CertProdoo">
                    <field name="responsible_user_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
