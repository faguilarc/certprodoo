<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Herencia de vista de formulario de usuario -->
    <record id="res_users_view_form_inherit" model="ir.ui.view">
        <field name="name">res.users.form.inherit.certprodoo.security</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page name="certprodoo_security" string="CertProdoo">
                    <group>
                        <group string="Rol y Tipo">
                            <field name="certprodoo_role_id"/>
                            <field name="user_type"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Vista de formulario de preferencias de usuario (mi cuenta) -->
    <record id="res_users_preferences_form_inherit" model="ir.ui.view">
        <field name="name">res.users.preferences.form.inherit.certprodoo.security</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='preferences']" position="after">
                <group string="CertProdoo">
                    <field name="certprodoo_role_id" readonly="1"/>
                    <field name="user_type" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Acción de Usuarios del Sistema -->
    <record id="action_system_users" model="ir.actions.act_window">
        <field name="name">Usuarios del Sistema</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('user_type', '=', 'system')]</field>
        <field name="context">{'default_user_type': 'system'}</field>
    </record>

    <!-- Acción de Usuarios Clientes -->
    <record id="action_client_users" model="ir.actions.act_window">
        <field name="name">Usuarios Clientes</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('user_type', 'in', ['client', 'client_online'])]</field>
        <field name="context">{'default_user_type': 'client'}</field>
    </record>
</odoo>
