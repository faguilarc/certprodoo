<?xml version="1.0" encoding="UTF-8"?>
<templates id="Dashboard" xml:space="preserve">
    <t t-name="DashboardSecurityDetails">
       <div class="row main-section">
            <div class="col user_active oh-payslip" >
                <div class="oh-card">
                    <div class="oh-card-body">
                        <div class="stat-widget-one">
                            <div class="stat-icon"><i class="fa fa-user"/></div>
                            <div class="stat-content">
                                <div class="stat-text"><h3>Usuarios Activos</h3></div>
                                <div class="stat-digit"><strong ><t t-esc="widget.users_info['user_active']"/></strong></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col company oh-payslip oh-user-disable">
                <div class="oh-card">
                    <div class="oh-card-body">
                        <div class="stat-widget-one">
                            <div class="stat-icon"><i class="fa fa-building"/></div>
                            <div class="stat-content">
                                <div class="stat-text">Compañias</div>
                                    <div class="stat-digit"><strong ><t t-esc="widget.users_info['companies']"/></strong></div>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col roles oh-payslip oh-user-online">
                <div class="oh-card">
                    <div class="oh-card-body">
                        <div class="stat-widget-one">
                            <div class="stat-icon"><i class="fa fa-user"/></div>
                            <div class="stat-content">
                                <div class="stat-text">Roles</div>
                                <div class="stat-digit"><strong ><t t-esc="widget.users_info['roles']"/></strong></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
       </div>
    </t>
</templates>