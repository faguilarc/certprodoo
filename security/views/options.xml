<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="options_tree">
            <field name="name">Opciones</field>
            <field name="model">security.options</field>
            <field name="arch" type="xml">
                <tree string="Opciones" class="tree_no_open" editable="bottom">
                    <field name="name" required="1"/>
                    <field name="model" options="{'no_create_edit': True}" />
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="options_action">
            <field name="name">Opciones</field>
            <field name="res_model">security.options</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede asignar un nombre a un modelo
                </p>
            </field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="options_tree"/>
        </record>

    </data>
</odoo>