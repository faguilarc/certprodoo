<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="permits_option_tree">
            <field name="name">Permisos por opciones</field>
            <field name="model">security.permits_option</field>
            <field name="arch" type="xml">
                <tree string="Permisos por opciones" class="tree_no_open" editable="bottom">
                    <field name="user" options="{'no_create_edit': True}" required="1"/>
                    <field name="options" options="{'no_create_edit': True}"/>
                    <field name="perm_show"/>
                    <field name="field_write"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="permits_option_action">
            <field name="name">Permisos por opciones</field>
            <field name="res_model">security.permits_option</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede asignar un permiso a un usuario para una opción.
                </p>
            </field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="permits_option_tree"/>
        </record>

    </data>
</odoo>