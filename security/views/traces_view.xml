        <record id="traces_tree_view" model="ir.ui.view">
            <field name="name">security.traces.tree</field>
            <field name="model">security.traces</field>
            <field name="arch" type="xml">
                <tree string="Trazas" class="tree_no_open" edit="false" create="false" delete="false">
                    <field name="register_time"/>
                    <field name="user"/>
                    <field name="description"/>
                    <field name="model"/>
                </tree>
            </field>
        </record>

        <record id="traces_search_view" model="ir.ui.view">
            <field name="name">security.traces.search</field>
            <field name="model">security.traces</field>
            <field name="arch" type="xml">
                <search string="Trazas">
                    <field name="model"/>
                    <field name="register_time"/>
                    <field name="user"/>
                </search>
            </field>
        </record>

        <record id="traces_act_window" model="ir.actions.act_window">
            <field name="name">Trazas</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">security.traces</field>
            <field name="view_mode">tree</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí verá los registros de actividad en el sistema.
                </p>
            </field>
        </record>
    </data>
</odoo>