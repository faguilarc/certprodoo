<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="users_inherit" model="ir.ui.view">
            <field name="name">Usuarios</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/><!--user_groups_view-->
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="attributes">
                    <attribute name="duplicate">0</attribute>
                </xpath>
                <xpath expr="//label[@for='login']" position="attributes">
                    <attribute name="string">Usuario</attribute>
                </xpath>
                <xpath expr="//field[@name='login']" position="attributes">
                    <attribute name="placeholder">Usuario</attribute>
                </xpath>
                <xpath expr="//field[@name='login']" position="after">
                    <group>
                        <field name="user_type" required="1" class="w-25" string="Tipo de registro"/>
                    </group>
                </xpath>
                <xpath expr="//notebook/page[@name='references']" position="after">
                    <page string="Información General">
                        <group>
                            <field name="rol" class="w-25" options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
        <record id="users_inherit_base" model="ir.ui.view">
            <field name="name">Usuarios</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_simple_form"/><!--user_groups_view-->
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="attributes">
                    <attribute name="duplicate">0</attribute>
                </xpath>
                <xpath expr="//label[@for='login']" position="attributes">
                    <attribute name="string">Usuario</attribute>
                </xpath>
                <xpath expr="//field[@name='login']" position="attributes">
                    <attribute name="placeholder">Usuario</attribute>
                </xpath>
                <xpath expr="//field[@name='login']" position="after">
                    <group>
                        <field name="user_type" required="1" class="w-25"/>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="users_inherit_tree" model="ir.ui.view">
            <field name="name">Usuarios</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_tree"/><!--user_groups_view-->
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='lang']" position="attributes">
                    <attribute name="invisible">True</attribute>
                </xpath>
                <xpath expr="//field[@name='company_id']" position="attributes">
                    <attribute name="invisible">True</attribute>
                </xpath>
                <xpath expr="//field[@name='company_id']" position="after">
                    <field name="user_type"/>
                </xpath>
            </field>
        </record>

        <record id="user_client_action_window" model="ir.actions.act_window">
            <field name="name">Usuarios de Cliente</field>
            <field name="res_model">res.users</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede agregar una nuevo usuario cliente al sistema
                </p>
            </field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('user_type','=', 'client')]</field>
        </record>

        <record id="user_action_window" model="ir.actions.act_window">
            <field name="name">Usuarios Gestores del Sistema</field>
            <field name="res_model">res.users</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede agregar una nuevo usuario gestor del sistema
                </p>
            </field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('user_type','=', 'system')]</field>
        </record>

    </data>
</odoo>