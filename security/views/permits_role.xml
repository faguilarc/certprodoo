<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="permits_roles_tree">
            <field name="name">Permisos por roles</field>
            <field name="model">security.permits_roles</field>
            <field name="arch" type="xml">
                <tree string="Permisos por roles" class="tree_no_open" editable="bottom">
                    <field name="rol" options="{'no_create_edit': True}" required="1"
                    attrs="{'readonly': [('is_default', '=', True)]}"
                    />
                    <field name="options" options="{'no_create_edit': True}" attrs="{'readonly': [('is_default', '=', True)]}"/>
                    <field name="perm_show" attrs="{'readonly': [('is_default', '=', True)]}"/>
                    <field name="field_write" attrs="{'readonly': [('is_default', '=', True)]}"/>
                    <field name="is_default" invisible="1"/>
                    <field name="company" invisible="1"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="permits_roles_action">
            <field name="name">Permisos por roles</field>
            <field name="res_model">security.permits_roles</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede asignar un permiso a un rol.
                </p>
            </field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="permits_roles_tree"/>
        </record>

    </data>
</odoo>