<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="permits_access" model="res.groups">
            <field name="name">Permisos de Acceso</field>
            <field name="comment">Permisos de Acceso</field>
            <field name="category_id" ref="permits_category"/>
        </record>

        <record id="generales_access" model="res.groups">
            <field name="name">Permisos de Acceso</field>
            <field name="comment">Permisos de Acceso</field>
            <field name="category_id" ref="generales_category"/>
        </record>
        <record id="group_professional_register_employee" model="res.groups">
            <field name="name">Registrador</field>
            <field name="category_id" ref="professional_register_employee_category"/>
        </record>
        <record id="group_professional_editor" model="res.groups">
            <field name="name">Editor</field>
            <field name="category_id" ref="professional_register_employee_category"/>
        </record>
        <record id="group_professional_managment" model="res.groups">
            <field name="name">Gestor</field>
            <field name="category_id" ref="professional_register_employee_category"/>
        </record>
        <record id="group_professional_consultant" model="res.groups">
            <field name="name">Consultor</field>
            <field name="category_id" ref="professional_register_employee_category"/>
            <field name="users" eval="[(4, ref('base.user_root'))]"/>
        </record>
        <record id="group_professional_client" model="res.groups">
            <field name="name">Cliente</field>
            <field name="category_id" ref="professional_register_employee_category"/>
        </record>
        <record id="group_professional_client_online" model="res.groups">
            <field name="name">Cliente Online</field>
            <field name="category_id" ref="professional_register_employee_category"/>
        </record>
        <record model="res.groups" id="group_professional_reigster_managment">
            <field name="name">Registrador/Gestor</field>
            <field name="implied_ids" eval="[(4, ref('group_professional_register_employee')), (4, ref('group_professional_managment'))]"/>
            <field name="category_id" ref="professional_register_employee_category"/>
<!--            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>-->
        </record>
        <record model="res.groups" id="group_professional_editor_managment">
            <field name="name">Editor/Gestor</field>
            <field name="implied_ids" eval="[(4, ref('group_professional_editor')), (4, ref('group_professional_managment'))]"/>
            <field name="category_id" ref="professional_register_employee_category"/>
        </record>
         <record model="res.groups" id="group_professional_superadmin">
            <field name="name">Superadmin</field>
            <field name="implied_ids" eval="[(4, ref('group_professional_editor')), (4, ref('group_professional_managment')), (4, ref('base.group_erp_manager'))]"/>
            <field name="category_id" ref="professional_register_employee_category"/>
         </record>
