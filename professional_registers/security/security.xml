            <field name="name">Professional Request Update: multi-company</field>
            <field name="model_id" ref="model_professional_registers_professional_request_update"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Regla para Reclamaciones: solo ver registros de su compañía -->
        <record id="professional_claim_request_company_rule" model="ir.rule">
            <field name="name">Professional Claim Request: multi-company</field>
            <field name="model_id" ref="model_professional_registers_claim_request"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Regla para Documentos de Expediente: solo ver registros de su compañía -->
