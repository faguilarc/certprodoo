            <field name="name">Expedient Document: multi-company</field>
            <field name="model_id" ref="model_professional_registers_expedient_document"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Regla para Historial de Expediente: solo ver registros de su compañía -->
        <record id="professional_expedient_history_company_rule" model="ir.rule">
            <field name="name">Expedient History: multi-company</field>
            <field name="model_id" ref="model_professional_registers_expedient_history"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Regla para Comunicaciones de Expediente: solo ver registros de su compañía -->
        <record id="professional_expedient_communication_company_rule" model="ir.rule">
            <field name="name">Expedient Communication: multi-company</field>
            <field name="model_id" ref="model_professional_registers_expedient_communication"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Regla para Historial de Procesos: solo ver registros de su compañía -->
        <record id="professional_process_history_company_rule" model="ir.rule">
            <field name="name">Process History: multi-company</field>
            <field name="model_id" ref="model_professional_registers_process_history"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>