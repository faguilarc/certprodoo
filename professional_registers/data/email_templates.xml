        <template id="email_template_state_change" name="Plantilla para Cambio de Estado">
        <t t-call="web.html_container">
            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                <t t-if="solicitud_data['action_type'] == 'detention'">
                    <h2 style="color: #e67e22;">Detención de solicitud</h2>
                </t>
                <t t-elif="solicitud_data['action_type'] == 'denial'">
                    <h2 style="color: #e74c3c;">Denegación de solicitud</h2>
                </t>
                <t t-elif="solicitud_data['action_type'] == 'cancellation'">
                    <h2 style="color: #7f8c8d;">Cancelación de Solicitud</h2>
                </t>
                <t t-else="">
                    <h2 style="color: #2c3e50;">Actualización de Estado</h2>
                </t>

                <p>Estimado/a <t t-esc="solicitud_data['solicitante']"/>,</p>

                <p>El estado de su solicitud ha sido actualizado:</p>

                <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
                    <tr>
                        <td style="padding: 8px; border-bottom: 1px solid #eee; width: 40%;">
                            <strong>Solicitud No.:</strong>
                        </td>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <t t-esc="solicitud_data['solicitud_no']"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <strong>Tipo de Trámite:</strong>
                        </td>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <t t-esc="solicitud_data['tipo_solicitud']"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <strong>Identificación:</strong>
                        </td>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <t t-esc="solicitud_data['identificacion']"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <strong>Estado anterior:</strong>
                        </td>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <t t-esc="solicitud_data['estado_actual']"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <strong>Nuevo estado:</strong>
                        </td>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <t t-esc="solicitud_data['estado_nuevo']"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <strong>Fecha de cambio:</strong>
                        </td>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <t t-esc="solicitud_data['fecha_cambio']"/>
                        </td>
                    </tr>
                </table>

                <!-- Causas del cambio -->
                <t t-if="solicitud_data['causas']">
                    <h3 style="margin-top: 20px;">Causas del cambio de estado:</h3>
                    <div style="background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin-bottom: 20px;">
                        <ul style="margin: 0; padding-left: 20px;">
                            <t t-foreach="solicitud_data['causas']" t-as="causa">
                                <li>
                                    <t t-esc="causa.name"/>
                                </li>
                            </t>
                        </ul>
                    </div>
                </t>

                <!-- Observaciones -->
                <t t-if="solicitud_data['observaciones']">
                    <h3>Observaciones:</h3>
                    <div style="background-color: #f8f9fa; padding: 15px; border-radius: 5px; margin-bottom: 20px;">
                        <p style="white-space: pre-line; margin: 0;">
                            <t t-esc="solicitud_data['observaciones']"/>
                        </p>
                    </div>
                </t>

                <!-- Mensajes específicos según acción -->
                <t t-if="solicitud_data['action_type'] == 'detention'">
                    <div style="margin-top: 20px; padding: 15px; background-color: #fef5e7; border-left: 4px solid #e67e22; border-radius: 4px;">
                        <strong>⚠️ Aviso:</strong>
                        <p style="margin: 10px 0 0 0;">
                            Su solicitud ha sido puesta en revisión.
                            Tiene <strong><t t-esc="solicitud_data['dias_habiles']"/> días hábiles</strong>
                            para completar los requisitos solicitados.
                        </p>
                    </div>
                </t>

                <t t-elif="solicitud_data['action_type'] == 'denial'">
                    <div style="margin-top: 20px; padding: 15px; background-color: #fdedec; border-left: 4px solid #e74c3c; border-radius: 4px;">
                        <strong>⚠️ Aviso:</strong>
                        <p style="margin: 10px 0 0 0;">
                            Su solicitud ha sido denegada. Para más información o si desea apelar esta decisión,
                            contacte con nuestra oficina.
                        </p>
                    </div>
                </t>

                <t t-elif="solicitud_data['action_type'] == 'cancellation'">
                    <div style="margin-top: 20px; padding: 15px; background-color: #f4f6f6; border-left: 4px solid #7f8c8d; border-radius: 4px;">
                        <strong>⚠️ Aviso:</strong>
                        <p style="margin: 10px 0 0 0;">
                            Su solicitud ha sido cancelada. Si considera que esto es un error,
                            contacte con nuestro equipo de atención al cliente.
                        </p>
                    </div>
                </t>

                <!-- Información de contacto -->
                <div style="margin-top: 30px; padding: 15px; background-color: #f0f8ff; border-radius: 4px;">
                    <p style="margin: 0 0 10px 0;">
                        <strong>Información de contacto:</strong>
                    </p>
                    <t t-if="solicitud_data['phone_from'] and solicitud_data['email_from']">
                        <p style="margin: 5px 0;">
                            Para consultas, puede escribir a:
                            <strong><t t-esc="solicitud_data['email_from']"/></strong>
                        </p>
                        <p style="margin: 5px 0;">
                            O llamar al:
                            <strong><t t-esc="solicitud_data['phone_from']"/></strong>
                        </p>
                    </t>
                    <t t-elif="solicitud_data['phone_from']">
                        <p style="margin: 5px 0;">
                            Para consultas, puede llamar al:
                            <strong><t t-esc="solicitud_data['phone_from']"/></strong>
                        </p>
                    </t>
                    <t t-elif="solicitud_data['email_from']">
                        <p style="margin: 5px 0;">
                            Para consultas, puede escribir a:
                            <strong><t t-esc="solicitud_data['email_from']"/></strong>
                        </p>
                    </t>
                </div>

                <!-- Firma -->
                <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #eee;">
                    <p style="margin: 0;">
                        Atentamente,
                        <br/>
                        <strong><t t-esc="env.user.company_id.name"/></strong>
                        <br/>

                    </p>
                </div>

                <!-- Footer -->
                <div style="margin-top: 30px; font-size: 12px; color: #7f8c8d; text-align: center;">
                    <p>
                        Este es un mensaje automático, por favor no responda directamente a este correo.
                    </p>
                </div>
            </div>
        </t>
    </template>

    <template id="email_template_validation_notice" name="Notificación de Solicitud en Validación">
        <t t-call="web.html_container">
            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                <h2 style="color: #3498db;">Su solicitud está en proceso de validación</h2>

                <p>Estimado/a<t t-esc="solicitud_data['solicitante']"/>,
                </p>

                <p>Le informamos que su solicitud ha pasado al estado de <strong>Validación</strong>.
                </p>

                <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
                    <tr>
                        <td style="padding: 8px; border-bottom: 1px solid #eee; width: 40%;">
                            <strong>Número de solicitud:</strong>
                        </td>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <t t-esc="solicitud_data['solicitud_no']"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <strong>Tipo de trámite:</strong>
                        </td>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <t t-esc="solicitud_data['tipo_solicitud']"/>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <strong>Fecha de solicitud:</strong>
                        </td>
                        <td style="padding: 8px; border-bottom: 1px solid #eee;">
                            <t t-esc="solicitud_data['fecha_solicitud']"/>
                        </td>
                    </tr>
                </table>

                <div style="background-color: #f1f8fe; border-left: 4px solid #3498db; padding: 15px; margin: 20px 0;">
                    <p>
                        <strong>⚠️ Importante:</strong>
                        Durante el proceso de validación:
                    </p>
                    <ul>
                        <li>No podrá modificar los datos de su solicitud</li>
                        <li>Recibirá una notificación cuando finalice la revisión</li>

                    </ul>
                </div>


                <p style="margin-top: 30px;">
                    Atentamente,
                    <br></br>
                    <t t-esc="solicitud_data['user']"/>
                </p>

                <div style="margin-top: 30px; font-size: 12px; color: #7f8c8d; text-align: center;">
                    <p>Este es un mensaje automático, por favor no responda directamente a este correo.</p>
                </div>
            </div>
        </t>
    </template>

</odoo>