<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_notification_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="data" t-as="docs">
                    <div class="page">
                        <div class="row">
                            <div class="col-12 text-center">
                                <h3>NOTIFICACIÓN DE
                                    <span t-esc="docs['action_type']" style="text-transform: uppercase;"/>
                                </h3>
                                <p>Fecha:
                                    <span t-esc="docs['fecha_cambio']" t-options='{"format": "dd/MM/yyyy"}'/>
                                </p>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-12">
                                <p>Estimado/a<span t-esc="docs['solicitante']"/>,
                                </p>
                                <p>Número de Solicitud:
                                    <span t-esc="docs['solicitud_no']"/>
                                </p>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-12">
                                <h4>Causas:</h4>
                                <ul>
                                    <t t-foreach="docs['cause_ids']" t-as="cause">
                                        <li>
                                            <strong><t t-esc="cause.name"/>:
                                            </strong>
                                            <p>
                                                <t t-esc="cause.description"/>
                                            </p>
                                        </li>
                                    </t>
                                </ul>
                            </div>
                        </div>

                        <div class="row mt-4" t-if="docs['observaciones']">
                            <div class="col-12">
                                <h4>Observaciones Adicionales:</h4>
                                <p t-esc="docs['observaciones']"/>
                            </div>
                        </div>

                        <div class="row mt-5">
                            <div class="col-6">
                                <p>Atentamente,</p>
                                <br/>
                                <br/>
                                <p>_______________________</p>
                                <p t-field="user.name"/>
                                <p t-field="user.partner_id.function"/>
                            </div>
                        </div>
                    </div>

                </t>
            </t>
        </t>
    </template>

    <record id="action_report_notification" model="ir.actions.report">
        <field name="name">Notificación</field>
        <field name="model">solicitud.observacion.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">professional_registers.report_notification_document</field>
        <field name="report_file">professional_registers.report_notification_document</field>
        <field name="print_report_name">'Notificación - %s' % object.solicitud_id.name</field>
        <field name="binding_model_id" ref="model_solicitud_observacion_wizard"/>
        <field name="binding_type">report</field>
    </record>
</odoo>