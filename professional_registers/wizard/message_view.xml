<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_custom_message_wizard_form" model="ir.ui.view">
            <field name="name">professional_registers.message_wizard.form</field>
            <field name="model">professional_registers.message_wizard</field>
            <field name="arch" type="xml">
                <form string="Wizard" create="false" edit="false">

                    <sheet>
                        <div class="oe_form_container">
                            <div class="oe_form_sheet">
                                <h3>
                                    <field name="message" optional="show" width="20%" force_save="1" readonly="1"/>
                                </h3>
                            </div>
                        </div>
                    </sheet>
                    <footer>
                        <field name="no_action" optional="hide" width="20%" force_save="1" readonly="1"/>
                        <button name="action_confirm" type="object" string="Aceptar" class="btn-primary"
                                attrs="{'invisible': [('no_action', '=', True)]}"/>
                        <button string="Cancelar" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>
        <record id="custom_message_wizard__act_window" model="ir.actions.act_window">
            <field name="name">Componente de mensajes</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">professional_registers.message_wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
