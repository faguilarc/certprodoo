<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="cancel_request_wizard_wizard_form_view" model="ir.ui.view">
            <field name="name">professional_registers.request_wizard.form</field>
            <field name="model">professional_registers.request_wizard</field>
            <field name="arch" type="xml">
                <form string="Atención!!!!">
                    <sheet>
                        <div class="oe_form_container">
                            <div class="oe_form_sheet">
                                <h3>Sus datos no están validados por la FUC. Debe dirigirse a la oficina más cercana de
                                    trámites para verificar su información.
                                </h3>
                                <br/>
                                <h3>Con su información verificada debe volver acceder al registro y llene nuevamente el
                                    formulario inicial.
                                </h3>
                                <footer class="justify-content-end">
                                    <button name="close" string="Cerrar" type="object"
                                            class="btn-primary" data-hotkey="q"/>

                                </footer>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="request_wizard_wizard_form_view" model="ir.ui.view">
            <field name="name">professional_registers.request_wizard.form</field>
            <field name="model">professional_registers.request_wizard</field>
            <field name="arch" type="xml">
                <form string="Atención!!!!">
                    <sheet>
                        <div class="oe_form_container">
                            <div class="oe_form_sheet">
                                <h3>Debe completar el perfil antes de generar una solicitud.</h3>
                                <footer class="justify-content-end">
                                    <button name="accept" string="Aceptar" type="object"
                                            class="btn-primary" data-hotkey="q"/>

                                </footer>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="request_wizard_wizard_form_view2" model="ir.ui.view">
            <field name="name">professional_registers.request_wizard.form</field>
            <field name="model">professional_registers.request_wizard</field>
            <field name="arch" type="xml">
                <form string="Generar solicitud">
                    <sheet>
                        <div class="oe_form_container">
                            <div class="oe_form_sheet">
                                <group col="4">
                                    <field name="request_date"/>
                                    <field name="procedure_type"
                                           options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"
                                           required="1"/>
                                </group>
                                <notebook>
                                    <page string="Documentos">
                                        <field name="documents_required">
                                            <tree class="tree_no_open" create="false" editable="bottom" delete="false">
                                                <field name="documents"
                                                       options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                                                <field name="attachment_ids" widget="many2many_binary"
                                                       string="Ficheros"/>
                                            </tree>
                                        </field>
                                    </page>
                                </notebook>
                                <footer class="justify-content-end">
                                    <button name="accept" string="Aceptar" type="object"
                                            class="btn-primary" data-hotkey="q"/>
                                    <button special="cancel" data-hotkey="z" string="Cancel" class="btn-secondary"/>
                                </footer>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="report_documents_required_wizard_act_window" model="ir.actions.act_window">
            <field name="name">Reporte de documentación por trámite</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">report.documents_required_wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>