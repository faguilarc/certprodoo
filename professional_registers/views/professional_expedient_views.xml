<!--        <field name="name">Comunicaciones de Expedientes</field>-->
<!--        <field name="res_model">professional_registers.expedient_communication</field>-->
<!--        <field name="view_mode">tree,form</field>-->
<!--    </record>-->

    <!-- Acción para historial de expediente -->
    <record id="action_expedient_history" model="ir.actions.act_window">
        <field name="name">Historial de Expedientes</field>
        <field name="res_model">professional_registers.expedient_history</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_professional_expedient_root"
              name="Expedientes"
              web_icon="professional_registers/static/description/icon_exp.png"
              sequence="10"/>

    <menuitem id="menu_professional_expedient"
              name="Expedientes"
              parent="menu_professional_expedient_root"
              action="action_professional_expedient"
              sequence="10"/>

    <!-- Submenús para elementos relacionados -->
