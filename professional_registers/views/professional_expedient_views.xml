    <record id="view_professional_expedient_kanban" model="ir.ui.view">
        <field name="name">professional.registers.expedient.kanban</field>
        <field name="model">professional_registers.expedient</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="state"/>
                <field name="expedient_number"/>
                <field name="professional_id"/>
                <field name="date_open"/>
                <field name="request_count"/>
                <field name="inscription_count"/>
                <field name="document_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="expedient_number"/>
                                    </strong>
                                    <div class="o_kanban_tags_section">
                                        <span class="badge badge-pill badge-info">
                                            <field name="state"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="o_kanban_tags_section">
                                    <span class="badge badge-secondary">
                                        <i class="fa fa-clipboard"/>
                                        Solicitudes:
                                        <field name="request_count"/>
                                    </span>
                                    <span class="badge badge-secondary">
                                        <i class="fa fa-id-card"/>
                                        Inscripciones:
                                        <field name="inscription_count"/>
                                    </span>
                                    <span class="badge badge-secondary">
                                        <i class="fa fa-file"/>
                                        Documentos:
                                        <field name="document_count"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="professional_id"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="date_open"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_professional_expedient_graph" model="ir.ui.view">
        <field name="name">professional.registers.expedient.graph</field>
        <field name="model">professional_registers.expedient</field>
        <field name="arch" type="xml">
            <graph string="Estadísticas de Expedientes">
                <field name="state"/>
                <field name="request_count" type="measure"/>
            </graph>
        </field>
    </record>

