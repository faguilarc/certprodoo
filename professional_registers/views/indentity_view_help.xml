<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="identity_form_view" model="ir.ui.view">
            <field name="name">professional_registers.identity.form</field>
            <field name="model">professional_registers.identity</field>
            <field name="arch" type="xml">
                <form string="Identidad" create="false" delete="false" edit="false">
                    <sheet>
                        <div>
                            <div class="oe_button_box" name="button_box">
                                <button type="object" name="report_identity" class="btn oe_stat_button">
                                    <i class="fa fa-fw o_button_icon fa-print"></i>
                                    <span>Imprimir</span>
                                </button>
                            </div>
                        </div>
                        <div class="oe_title">
                            <label for="full_name" string="Nombre y apellidos"/>
                            <h1>
                                <field name="full_name"  placeholder="Nombre y apellidos" readonly="1" force_save="1"/>
                            </h1>
                        </div>
                        <group col="4">
                            <field name="inscription_number" readonly="1" force_save="1"/>
                            <field name="profession" readonly="1" force_save="1"/>
                            <field name="date" readonly="1" force_save="1"/>
                        </group>
                    </sheet>
                    <footer>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>