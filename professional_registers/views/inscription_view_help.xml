<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="inscription_help_form_view" model="ir.ui.view">
            <field name="name">professional_registers.inscriptions_help.form</field>
            <field name="model">professional_registers.inscriptions_help</field>
            <field name="arch" type="xml">
                <form string="Inscripciones" create="false" delete="false" edit="false">
                    <sheet>
                        <div>
                            <div class="oe_button_box" name="button_box">
                                <button type="object" name="report_inscription" class="btn oe_stat_button">
                                    <i class="fa fa-fw o_button_icon fa-print"></i>
                                    <span>Imprimir</span>
                                </button>
                            </div>
                        </div>
                        <div class="oe_title">
                            <label for="full_name" string="Nombre y apellidos"/>
                            <h1>
                                <field name="full_name" placeholder="Nombre y apellidos" readonly="1" force_save="1"/>
                            </h1>
                        </div>
                        <group col="4">
                            <field name="inscription_number" readonly="1" force_save="1"/>
                            <field name="identity" readonly="1" force_save="1"/>
                            <field name="email" readonly="1" force_save="1"/>
                            <field name="profession" readonly="1" force_save="1"/>
                            <field name="date" readonly="1" force_save="1"/>
                            <field name="state" readonly="1" force_save="1"/>
                        </group>
                        <notebook>
                            <page string="Histórico de Cambios">
                                <field name="history_ids" widget="one2many_list"
                                       options="{'create': False, 'edit': False, 'delete': False}" readonly="1">
                                    <tree limit="8">
                                        <field name="state_id"/>
                                        <field name="date"/>
                                        <field name="user_id"/>
                                        <field name="observation"/>
                                        <!-- Filtros -->
                                        <!--                                        <filter string="Estado" name="filter_state" domain="[]"-->
                                        <!--                                                context="{'group_by': 'state_id'}"/>-->
                                        <!--                                        <filter string="Usuario" name="filter_user" domain="[]"-->
                                        <!--                                                context="{'group_by': 'user_id'}"/>-->
                                        <!--                                        <filter string="Últimos 7 días" name="filter_last_7_days"-->
                                        <!--                                                domain="[('date', '>=', (context_today() - timedelta(days=7)).strftime('%Y-%m-%d'))]"/>-->
                                        <!--                                        <filter string="Este Mes" name="filter_this_month"-->
                                        <!--                                                domain="[('date', '>=', context_today().strftime('%Y-%m-01'))]"/>-->
                                        <!--                                        &lt;!&ndash; Grupos &ndash;&gt;-->
                                        <!--                                        <groupby string="Agrupar por Estado" name="group_by_state"-->
                                        <!--                                                 context="{'group_by': 'state_id'}"/>-->
                                        <!--                                        <groupby string="Agrupar por Usuario" name="group_by_user"-->
                                        <!--                                                 context="{'group_by': 'user_id'}"/>-->
                                    </tree>
                                </field>
                            </page>

                        </notebook>
                    </sheet>
                    <footer>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>