        <record id="professional_request_detail" model="ir.actions.report">
            <field name="name">Solicitud de Inscripción</field>
            <field name="model">professional_registers.professional_request</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">professional_registers.report_professional_request</field>
            <field name="report_file">professional_registers.report_professional_request</field>
