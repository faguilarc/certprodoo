<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="inscription_form_view" model="ir.ui.view">
            <field name="name">professional_registers.inscription.form</field>
            <field name="model">professional_registers.inscription</field>
            <field name="arch" type="xml">
                <form string="Inscripciones" create="false" delete="false" duplicate="false">
                    <header>
                        <field name="states" widget="statusbar"/>
                        <button string="Cancelar" type="object" name="cancel"
                                attrs="{'invisible': ['|',('priority','!=', 1), ('is_view_datails', '=', True)]}"/>
                        <button string="Reaprobar" type="object" name="reset"
                                attrs="{'invisible': ['|',('priority','!=', 2), ('is_view_datails', '=', True)]}"/>

                    </header>
                    <sheet>
                        <field name="id" invisible="1"/>
                        <field name="force_erase" invisible="1"/>
                        <field name="profile_id" invisible="1"/>
                        <div>
                            <div class="oe_button_box" name="button_box">
<!--                                <button name="action_sync_with_profile" type="object" string="Sincronizar con Perfil"-->
<!--                                        class="btn-primary"-->
<!--                                        attrs="{'invisible': [('profile_id', '=', False)]}"/>-->
                                <button type="object" name="report_inscription" class="btn oe_stat_button"
                                        attrs="{'invisible': [('priority','==', 2)]}">
                                    <i class="fa fa-fw o_button_icon fa-print"></i>
                                    <span>Imprimir</span>
                                </button>
                            </div>
                        </div>
                        <field name="priority" invisible="1"/>
                        <field name="is_view_datails" invisible="1"/>
                        <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"
                               readonly="1" force_save="1"/>
                        <div class="oe_title">
                            <label for="full_name" string="Nombre y apellidos"/>
                            <h1>
                                <field name="full_name" placeholder="Nombre y apellidos" required="1" readonly="1"
                                       force_save="1"/>
                            </h1>
                        </div>
                        <group col="6">
                            <field name="name" required="1" readonly="1" force_save="1"/>
                            <field name="first_last_name" required="1" readonly="1" force_save="1"/>
                            <field name="second_last_name" required="1" readonly="1" force_save="1"/>
                            <field name="nationality_id" required="1" readonly="1" force_save="1"/>
                            <field name="identity" required="1" readonly="1" force_save="1"/>
                            <field name="email" readonly="1" force_save="1"/>
                            <field name="date" readonly="1" force_save="1"/>
                            <!--                            <field name="was_payment" invisible="1"/>-->
                            <!--                            <field name="payment_type" attrs="{'invisible': [('was_payment', '=', False)]}" readonly="1" force_save="1"/>-->
                            <!--                            <field name="id_transaction" attrs="{'invisible': [('was_payment', '=', False)], 'readonly': [('payment_type', '=', 'pagado')]}"/>-->
                        </group>
                        <notebook>
                            <page string="Notas al margen">
                                <field name="side_notes_list">
                                    <tree class="tree_no_open" editable="bottom" delete="false">
                                        <field name="date"/>
                                        <field name="side_notes"/>
                                        <field name="attachment_ids" widget="many2many_binary"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Certificación" attrs="{'invisible': [('priority', '!=', 1)]}"
                                  groups="security.group_professional_editor,security.group_professional_consultant,security.group_professional_editor_managment,security.group_professional_superadmin">
                                <div>
                                    <separator string="Archivos Adjuntos"/>
                                    <group>
                                        <div>
                                            <field name="certificate_attachment" widget="many2many_binary"/>
                                        </div>
                                    </group>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="inscription_tree_view" model="ir.ui.view">
            <field name="name">professional_registers.inscription.tree</field>
            <field name="model">professional_registers.inscription</field>
            <field name="arch" type="xml">
                <tree string="Inscripciones" create="false" delete="false">
                    <field name="inscription_number" optional="show"/>
                    <field name="full_name" optional="show"/>
                    <field name="date" optional="show"/>
                    <field name="nationality_id" optional="show"/>
                    <field name="profession" optional="show"/>
                    <field name="states" optional="show"/>
                    <field name="user_on_charge" optional="show"/>
                    <field name="request_id" optional="show"/>
                    <field name="retired" optional="show"/>
                    <field name="certification" optional="show"/>
                    <field name="was_payment" invisible="1"/>
                    <field name="payment_type" optional="show"/>
                    <button
                            name="go_to_inscription"
                            type="object"
                            string=""
                            icon="/professional_registers/static/img/show.png"
                    />
                    <!--                    <button-->
                    <!--                        name="go_to_identity"-->
                    <!--                        type="object"-->
                    <!--                        string=""-->
                    <!--                        icon="/professional_registers/static/img/ci.png"-->
                    <!--                    />-->
                </tree>
            </field>
        </record>
        <record id="inscription_search_view" model="ir.ui.view">
            <field name="name">professional_registers.inscription.search</field>
            <field name="model">professional_registers.inscription</field>
            <field name="arch" type="xml">
                <search string="Inscripciones">
                    <field name="full_name" string="Nombre y apellidos"/>
                    <field name="nationality_id" string="Nacionalidad"/>
                    <field name="profession" string="Profesión"/>
                    <field name="states" string="Estado"/>
                    <field name="payment_type" string="Pago"/>
                    <field name="year"/>
                    <field name="sex"/>
                    <field name="country_state"/>
                </search>
            </field>
        </record>
        <record id="inscription_act_window" model="ir.actions.act_window">
            <field name="name">Registro de inscripciones</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">professional_registers.inscription</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede registrar una nueva inscripción
                </p>
            </field>
            <field name="context">{'search_default_year': (context_today()).strftime('%Y')}</field>
        </record>
    </data>
</odoo>