<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_solicitud_observacion_wizard_form" model="ir.ui.view">
        <field name="name">solicitud.observacion.wizard.form</field>
        <field name="model">solicitud.observacion.wizard</field>
        <field name="arch" type="xml">
            <form string="Ingresar Observaciones para Cambio de Estado">
                <sheet>
                    <!-- Grupo principal con campos clave -->
                    <group>
                        <group string="Información Básica">

                            <field name="email_to" required="1" placeholder="correo@ejemplo.com" readonly="1"/>

                            <field name="action_type" widget="radio" options='{"horizontal": true}' readonly="1"/>

                        </group>

                        <group string="Detalles de la Acción">
                            <field name="cause_ids"
                                   widget="many2many_tags"
                                   attrs="{'required': [('action_type', 'in', ['detention','denial','cancellation'])]}"
                                   placeholder="Seleccione las causas..."/>

                            <field name="counter"
                                   attrs="{'invisible': [('action_type', '!=', 'detention'), ],
                                           'required': [('action_type', '=', 'detention')]}"
                                   placeholder="Días hábiles para resolver los requerimientos"
                                   class="oe_inline"/>

                            <!-- Nuevo campo para documentos adjuntos -->
                            <field name="attachment_ids"
                                   string="Documentos Adjuntos"
                                   widget="many2many_binary"
                                   context="{'default_res_model': 'solicitud.observacion.wizard', 'default_res_id': id}"
                                   placeholder="Arrastre archivos aquí o haga clic para seleccionar"/>
                        </group>
                    </group>
                    <group string="Datos de Asistencia">

                            <field name="email_from" required="1" placeholder="correo@ejemplo.com"/>
                            <field name="phone_from" required="1" />

                        </group>

                    <!-- Grupo para observaciones con más espacio -->
                    <group>
                        <field name="observaciones"
                               placeholder="Ingrese aquí las observaciones detalladas para el cambio de estado..."
                               nolabel="1"
                               class="oe_edit_only"
                               style="min-height: 60px;"/>
                    </group>


                    <!-- Notebook con pestañas para vistas previas -->
                    <notebook>
                        <page string="Vista Previa del Email" attrs="{'invisible': [('preview_email', '=', False)]}">
                            <div style="height: 300px; overflow: auto; border: 1px solid #dee2e6; padding: 10px;">
                                <field name="preview_email" readonly="1" nolabel="1"/>
                            </div>
                        </page>

<!--                        <page string="Vista Previa del Documento"-->
<!--                              attrs="{'invisible': [('preview_document', '=', False)]}">-->
<!--                            <div style="height: 300px; overflow: auto; border: 1px solid #dee2e6; padding: 10px;">-->
<!--                                <field name="preview_document" readonly="1" nolabel="1"/>-->
<!--                            </div>-->
<!--                        </page>-->
                    </notebook>
                </sheet>

                <!-- Pie de página con botones -->
                <footer>
                    <button string="Enviar "
                            name="action_send_and_generate"
                            type="object"
                            class="btn-primary"
                            attrs="{'invisible': [('action_type', '=', False)]}"/>

                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_solicitud_observacion_wizard" model="ir.actions.act_window">
        <field name="name">Observaciones para Cambio de Estado</field>
        <field name="res_model">solicitud.observacion.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_action_type': 'detention'}</field>
    </record>











</odoo>