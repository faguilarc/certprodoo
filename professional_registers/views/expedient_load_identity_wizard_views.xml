<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_expedient_load_identity_wizard_form" model="ir.ui.view">
        <field name="name">expedient.load.identity.wizard.form</field>
        <field name="model">expedient.load.identity.wizard</field>
        <field name="arch" type="xml">
            <form string="Cargar Registros por Identity">
                <sheet>
                    <group>
                        <field name="expedient_id" invisible="1"/>
                        <field name="identity" placeholder="Ingrese el número de identity"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_load_records" type="object" string="Cargar Registros" class="btn-primary"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>