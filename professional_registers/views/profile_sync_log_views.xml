<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_profile_sync_log_tree" model="ir.ui.view">
        <field name="name">professional.registers.profile.sync.log.tree</field>
        <field name="model">professional_registers.profile_sync_log</field>
        <field name="arch" type="xml">
            <tree string="Registro de Sincronización">
                <field name="date"/>
                <field name="profile_id"/>
                <field name="user_id"/>
                <field name="sync_type"/>
                <field name="source_model"/>
                <field name="inscriptions_updated"/>
                <field name="details"/>
            </tree>
        </field>
    </record>

    <record id="view_profile_sync_log_form" model="ir.ui.view">
        <field name="name">professional.registers.profile.sync.log.form</field>
        <field name="model">professional_registers.profile_sync_log</field>
        <field name="arch" type="xml">
            <form string="Detalle de Sincronización">
                <sheet>
                    <group>
                        <group>
                            <field name="profile_id"/>
                            <field name="date"/>
                            <field name="user_id"/>
                            <field name="sync_type"/>
                        </group>
                        <group>
                            <field name="source_model"/>
                            <field name="source_id"/>
                            <field name="inscriptions_updated"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Detalles">
                            <field name="details" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_profile_sync_log_search" model="ir.ui.view">
        <field name="name">professional.registers.profile.sync.log.search</field>
        <field name="model">professional_registers.profile_sync_log</field>
        <field name="arch" type="xml">
            <search string="Buscar Registro de Sincronización">
                <field name="profile_id"/>
                <field name="user_id"/>
                <field name="source_model"/>
                <separator/>
                <filter name="today" string="Hoy" domain="[('date', '>=', datetime.datetime.now().strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter name="this_week" string="Esta Semana" domain="[('date', '>=', (datetime.datetime.now() - datetime.timedelta(days=7)).strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter name="this_month" string="Este Mes" domain="[('date', '>=', datetime.datetime.now().strftime('%Y-%m-01 00:00:00'))]"/>
                <separator/>
                <filter name="profile_sync" string="Sincronización de Perfil" domain="[('sync_type', '=', 'profile')]"/>
                <filter name="update_sync" string="Sincronización de Actualización" domain="[('sync_type', '=', 'update')]"/>
                <filter name="manual_sync" string="Sincronización Manual" domain="[('sync_type', '=', 'manual')]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_profile" string="Perfil" context="{'group_by': 'profile_id'}"/>
                    <filter name="group_user" string="Usuario" context="{'group_by': 'user_id'}"/>
                    <filter name="group_sync_type" string="Tipo de Sincronización" context="{'group_by': 'sync_type'}"/>
                    <filter name="group_date" string="Fecha" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_profile_sync_log" model="ir.actions.act_window">
        <field name="name">Registro de Sincronización</field>
        <field name="res_model">professional_registers.profile_sync_log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_profile_sync_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay registros de sincronización
            </p>
            <p>
                Los registros de sincronización aparecerán aquí cuando se actualicen perfiles o se aprueben solicitudes de actualización.
            </p>
        </field>
    </record>


</odoo>