        <!-- ============================================ -->
        <!-- VISTA TREE (LISTA) PARA DIRECTORIOS DMS -->
        <!-- ============================================ -->
        <record id="view_dms_directory_expedient_tree" model="ir.ui.view">
            <field name="name">dms.directory.expedient.tree</field>
            <field name="model">dms.directory</field>
            <field name="arch" type="xml">
                <tree string="Carpetas de Expedientes">
                    <field name="name"/>
                    <field name="create_date"/>
                    <field name="res_model"/>
                    <field name="res_id"/>
                    <field name="parent_id"/>
                    <field name="count_directories"/>
                    <field name="count_files"/>

                </tree>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- VISTA FORMULARIO PARA DIRECTORIOS DMS -->
        <!-- ============================================ -->
        <record id="view_dms_directory_expedient_form" model="ir.ui.view">
            <field name="name">dms.directory.expedient.form</field>
            <field name="model">dms.directory</field>
            <field name="arch" type="xml">
                <form string="Carpeta DMS">
                    <sheet>
                        <!--                        <div class="oe_button_box" name="button_box">-->
                        <!--                            <button name="action_open_dms_directory" type="object" class="oe_stat_button" icon="fa-folder-open">-->
                        <!--                                <div class="o_field_widget o_stat_info">-->
                        <!--                                    <span class="o_stat_text">Abrir</span>-->
                        <!--                                </div>-->
                        <!--                            </button>-->
                        <!--                        </div>-->
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="parent_id"/>
                                <field name="is_root_directory"/>
                            </group>
                            <group>
                                <field name="res_model"/>
                                <field name="res_id"/>
                                <field name="storage_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Estadísticas">
                                <group>
                                    <group>
                                        <field name="count_directories"/>
                                        <field name="count_files"/>
                                    </group>
                                    <group>

                                        <field name="create_date"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Archivos">
                                <field name="file_ids">
                                    <tree>
                                        <field name="name"/>
                                        <field name="create_date"/>
                                        <field name="size"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Subcarpetas">
                                <field name="child_directory_ids">
                                    <tree>
                                        <field name="name"/>
                                        <field name="create_date"/>
                                        <field name="count_files"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- ACCIÓN PARA VER TODAS LAS CARPETAS DE EXPEDIENTES -->
        <!-- ============================================ -->
        <record id="action_dms_expedient_directories" model="ir.actions.act_window">
            <field name="name">Carpetas de Expedientes DMS</field>
            <field name="res_model">dms.directory</field>
            <field name="view_mode">kanban,tree,form</field>
<!--            <field name="view_id" ref="view_dms_directory_expedient_kanban"/>-->
            <field name="domain">[('res_model', '=', 'professional_registers.expedient')]</field>
            <field name="context">{'search_default_group_by_parent': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay carpetas de expedientes creadas
                </p>
                <p>
                    Las carpetas se crean automáticamente al generar un nuevo expediente.
                </p>
            </field>
        </record>


        <!-- ============================================ -->
        <!-- MENÚ PRINCIPAL -->
        <!-- ============================================ -->
        <menuitem id="menu_dms_expedient_root"
                  name="Carpetas de Expedientes"
                  parent="professional_registers.menu_professional_expedient_root"
                  sequence="50"
                  groups="security.group_professional_superadmin,security.group_professional_register_employee,security.group_professional_editor_managment"/>

        <!-- Menú para ver carpetas de expedientes -->
        <menuitem id="menu_dms_expedient_directories"
                  name="Carpetas de Expedientes"
                  parent="menu_dms_expedient_root"
                  action="action_dms_expedient_directories"
                  sequence="10"
                  groups="security.group_professional_superadmin,security.group_professional_register_employee,security.group_professional_editor_managment"/>


    </data>
</odoo>