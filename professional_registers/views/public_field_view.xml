<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_public_field_tree" model="ir.ui.view">
        <field name="name">professional_registers.public_field.tree</field>
        <field name="model">professional_registers.public_field</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="category"/>
                <field name="fields_ids"/>

                <button
                        name="unlink"
                        type="object"
                        string="Eliminar"
                        class="oe_unlink"
                        confirm="¿Está seguro de que desea eliminar este campo público?"
                />
            </tree>
        </field>
    </record>

    <record id="view_public_field_form" model="ir.ui.view">
        <field name="name">professional_registers.public_field.form</field>
        <field name="model">professional_registers.public_field</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="request_id" invisible="1"/>
                        <field name="category"/>
                        <field name="fields_ids"
                               widget="many2many_tags"
                               options="{'no_create': True, 'no_edit': True}"/>

                    </group>
                    <!-- Sección para mostrar campos existentes -->
                    <group string="Campos Públicos Configurados"
                           attrs="{'invisible': [('request_id', '=', False)]}">
                        <field name="existing_public_fields" nolabel="1">
                            <tree delete="1">
                                <field name="category"/>
                                <field name="fields_ids" widget="many2many_tags"/>

                                <button
                                        name="unlink"
                                        type="object"
                                        string="Eliminar"
                                        class="oe_unlink"
                                        confirm="¿Está seguro de que desea eliminar este campo público?"
                                />
                            </tree>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button string="Guardar" type="object" name="action_save" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_public_field" model="ir.actions.act_window">
        <field name="name">Campos Públicos</field>
        <field name="res_model">professional_registers.public_field</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_request_id': active_id}</field>
    </record>

</odoo>