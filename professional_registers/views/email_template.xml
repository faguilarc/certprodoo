<odoo>
    <data>
        <record model="ir.ui.view" id="email_form">
            <field name="name">Correo Electrónico</field>
            <field name="model">send.email</field>
            <field name="inherit_id" ref="mail.email_compose_message_wizard_form"/>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='save_as_template']" position="attributes">
                    <attribute name="invisible">True</attribute>
                </xpath>
                <xpath expr="//field[@name='template_id']" position="attributes">
                    <attribute name="invisible">True</attribute>
                </xpath>
                <xpath expr="//span[@name='document_followers_text']" position="attributes">
                    <attribute name="invisible">True</attribute>
                </xpath>
                <xpath expr="//field[@name='subject']" position="attributes">
                    <attribute name="string">Asunto</attribute>
                </xpath>
            </field>
        </record>

        <record id="template_state_change" model="mail.template">
            <field name="name">Notificación de Cambio de Estado Crítico</field>
            <field name="model_id" ref="model_professional_registers_professional_request"/>
            <field name="subject">Solicitud ${object.request_number} - Cambio a ${object.states.name}</field>
            <field name="body_html">
                <![CDATA[
            <p>Estimado/a ${object.full_name},</p>
            <p>Su solicitud <strong>${object.request_number}</strong> ha cambiado al estado: <strong>${object.states.name}</strong>.</p>
            % if object.observation:
                <p><strong>Observaciones:</strong> ${object.observation}</p>
            % endif
            <p>Fecha del cambio: ${format_datetime(object.write_date, tz='America/Havana', dt_format='dd/MM/yyyy HH:mm')}</p>
            <p>Para más detalles, acceda a su perfil en la plataforma.</p>
        ]]>
            </field>
        </record>

        <record id="template_document_notes" model="mail.template">
            <field name="name">Notificación de Observaciones en Documentos</field>
            <field name="model_id" ref="model_professional_registers_professional_request"/>
            <field name="subject">Observaciones en documentos de la solicitud ${object.request_number}</field>
            <field name="body_html">
                <![CDATA[
            <p>Hola ${object.full_name},</p>
            <p>Se han registrado observaciones en los documentos de su solicitud:</p>
            <ul>
                % for doc in object.documents_required.filtered(lambda d: d.commet):
                    <li>
                        <strong>${doc.documents.name}:</strong>
                        ${doc.commet or 'Sin comentarios'}
                    </li>
                % endfor
            </ul>
            <p>Acceda a la plataforma para subsanar los requerimientos.</p>
        ]]>
            </field>
        </record>


        <record id="email_action" model="ir.actions.act_window">
            <field name="name">Correo Electrónico</field>
            <field name="res_model">send.email</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>