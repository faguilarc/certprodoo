<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="claim_request_tree_view" model="ir.ui.view">
            <field name="name">claim.request.tree.view</field>
            <field name="model">professional_registers.claim_request</field>
            <field name="arch" type="xml">
                <tree string="Reclamaciones" create="false">
                    <field name="request_number"/>
                    <field name="date_request"/>
                    <field name="original_request_id"/>
                    <field name="claim_type"/>
                    <field name="claim_status"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="user_id"/>
                    <field name="user_on_charge"/>

                </tree>
            </field>
        </record>

        <record id="claim_request_search_view" model="ir.ui.view">
            <field name="name">claim.request.search.view</field>
            <field name="model">professional_registers.claim_request</field>
            <field name="arch" type="xml">
                <search string="Buscar Reclamaciones">
                    <field name="request_number"/>
                    <field name="original_request_id"/>
                    <field name="user_id"/>
                    <field name="user_on_charge"/>
                    <field name="claim_type"/>
                    <field name="claim_status"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <separator/>
                    <filter name="draft" string="Borrador" domain="[('claim_status','=','draft')]"/>
                    <filter name="in_process" string="En Proceso" domain="[('claim_status','=','in_process')]"/>
                    <filter name="evaluating" string="En Evaluación" domain="[('claim_status','=','evaluating')]"/>
                    <filter name="approved" string="Aprobadas" domain="[('claim_status','=','approved')]"/>
                    <filter name="rejected" string="Rechazadas" domain="[('claim_status','=','rejected')]"/>
                    <separator/>
                    <!--                    <filter name="my_claims" string="Mis Reclamaciones" domain="[('user_id','=',uid)]"/>-->
                    <filter name="my_to_process" string="Asignadas a Mí" domain="[('user_on_charge','=',uid)]"/>
                    <separator/>
                    <group expand="0" string="Agrupar por">
                        <filter name="group_claim_type" string="Tipo de Reclamación"
                                context="{'group_by':'claim_type'}"/>
                        <filter name="group_status" string="Estado" context="{'group_by':'claim_status'}"/>
                        <filter name="group_user" string="Usuario" context="{'group_by':'user_id'}"/>
                        <filter name="group_date" string="Fecha" context="{'group_by':'date_request'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="claim_request_form_view" model="ir.ui.view">
            <field name="name">claim.request.form.view</field>
            <field name="model">professional_registers.claim_request</field>
            <field name="arch" type="xml">
                <form string="Reclamación" duplicate="false" create="false">
                    <header>
                        <field name="claim_status" widget="statusbar" readonly="1"/>
                        <button name="submit_claim" string="En Proceso" type="object"
                                attrs="{'invisible': [('claim_status','!=','draft')]}"/>
                        <button name="send_email" string="Generar Correo" type="object"
                                attrs="{'invisible': [('claim_status','!=','in_process')]}"/>
                        <button name="evaluate_claim" string="En Validación" type="object"
                                attrs="{'invisible': [('claim_status','!=','in_process')]}"
                                groups="!security.group_professional_client_online"/>
                        <button name="approve_claim" string="Con Lugar" type="object"
                                attrs="{'invisible': [('claim_status','!=','evaluating')]}"
                                groups="!security.group_professional_client_online"/>
                        <button name="cancel_claim" string="Con Lugar en Parte" type="object"
                                attrs="{'invisible': [('claim_status','!=','evaluating')]}"
                                groups="!security.group_professional_client_online"/>
                        <button name="reject_claim" string="Sin Lugar" type="object"
                                attrs="{'invisible': [('claim_status','!=','evaluating')]}"
                                groups="!security.group_professional_client_online"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="go_to_original_request" type="object" string="Solicitud Original"
                                    class="oe_stat_button" icon="fa-folder-open-o">

                            </button>
                        </div>

                        <!-- Zona de avatar y título -->
                        <div class="o_form_sheet_bg">
                            <div class="oe_button_box" name="button_box"/>
                            <div class="o_right">
                                <field name="image" widget="image"
                                       class="oe_avatar"
                                       options="{'preview_image': 'image'}" required="1"/>
                            </div>
                            <div class="oe_title">
                                <label for="full_name" string="Nombre y apellidos"/>
                                <h1>
                                    <field name="full_name" readonly="1" required="1" force_save="1"/>
                                </h1>
                                <h3>
                                    <field name="identity" readonly="1"/>
                                    <span attrs="{'invisible': [('id_fuc', '=', False)]}">
                                        |
                                        <field name="id_fuc" readonly="1"/>
                                    </span>
                                </h3>
                            </div>
                        </div>

                        <!-- Separador -->
                        <div class="o_horizontal_separator"></div>


                        <group>
                            <group>
                                <field name="request_number" readonly="1"/>
                                <field name="date_request" readonly="1"/>
                                <field name="priority" invisible="1"/>
                                <field name="show_answer" invisible="1"/>
                                <field name="user_id" readonly="1"
                                       options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"
                                       attrs="{'invisible': [('claim_status', '!=', 'approved')]}"/>
                                <field name="user_on_charge"
                                       options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"
                                       readonly="1"/>

                            </group>
                            <group>
                                <field name="original_request_id" readonly="1"
                                       options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                                <field name="claim_type" readonly="1"/>
                                <field name="claim_status" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Detalles de la Reclamación">
                                <group>
                                    <field name="claim_reason" nolabel="1"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                           placeholder="Describa los motivos de su reclamación..."/>
                                </group>
                                <group string="Evidencias Adjuntas">
                                    <field name="evidence_attachment_ids" widget="many2many_binary" nolabel="1"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                </group>
                            </page>
                            <page string="Respuesta"
                                  attrs="{'invisible': [  ('show_answer', '=', False)]}">
                                <group>
                                    <field name="response_date"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="response_user"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="response_text" nolabel="1"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                           placeholder="Respuesta a la reclamación..."/>
                                    <field name="attachment_ids" widget="many2many_binary" nolabel="1"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                </group>
                            </page>

                            <page string="Historial">
                                <field name="history_ids" readonly="1">
                                    <tree>
                                        <field name="date"/>
                                        <field name="user_id"/>
                                        <field name="state_id"/>
                                        <field name="observation"/>
                                    </tree>
                                </field>
                            </page>

                        </notebook>
                    </sheet>
                    <!--                    <div class="oe_chatter">-->
                    <!--                        <field name="message_follower_ids" widget="mail_followers"/>-->
                    <!--                        <field name="message_ids" widget="mail_thread"/>-->
                    <!--                    </div>-->
                </form>
            </field>
        </record>

        <record id="claim_request_kanban_view" model="ir.ui.view">
            <field name="name">claim.request.kanban.view</field>
            <field name="model">professional_registers.claim_request</field>
            <field name="arch" type="xml">
                <kanban default_group_by="claim_status">
                    <field name="claim_status"/>
                    <field name="request_number"/>
                    <field name="date_request"/>
                    <field name="original_request_id"/>
                    <field name="claim_type"/>
                    <field name="user_id"/>
                    <field name="user_on_charge"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="oe_kanban_content">
                                    <div class="oe_kanban_details">
                                        <strong class="o_kanban_record_title">
                                            <field name="request_number"/>
                                        </strong>
                                        <div class="o_kanban_tags_section">
                                            <span class="badge badge-pill badge-info">
                                                <field name="claim_type"/>
                                            </span>
                                        </div>
                                        <div>
                                            <field name="original_request_id"/>
                                        </div>
                                        <div>
                                            <field name="user_id"/>
                                        </div>
                                        <div>
                                            <field name="date_request"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="claim_request_action" model="ir.actions.act_window">
            <field name="name">Reclamaciones</field>
            <field name="res_model">professional_registers.claim_request</field>
            <field name="view_mode">tree,kanban,form</field>
            <!--            <field name="domain">[('user_id', '=', uid)]</field>-->
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay reclamaciones registradas
                </p>
                <p>
                    Cree una nueva reclamación para disputar una denegación o cancelación de solicitud.
                </p>
            </field>
        </record>

        <!-- Secuencia para reclamaciones -->
        <record id="sequence_claim_request" model="ir.sequence">
            <field name="name">Secuencia de Reclamaciones</field>
            <field name="code">professional.claim.request</field>
            <field name="prefix">REC/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range">True</field>
        </record>

        <!-- Rango de fechas para el año actual -->
        <record id="sequence_claim_request_range_current" model="ir.sequence.date_range">
            <field name="sequence_id" ref="sequence_claim_request"/>
            <field name="date_from" eval="datetime.now().strftime('%Y-01-01')"/>
            <field name="date_to" eval="datetime.now().strftime('%Y-12-31')"/>
            <field name="number_next">1</field>
            <field name="number_next_actual">1</field>
        </record>

    </data>


</odoo>