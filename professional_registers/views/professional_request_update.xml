<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Vista de formulario-->
    <record id="view_professional_request_update_form" model="ir.ui.view">
        <field name="name">professional.request.update.form</field>
        <field name="model">professional_registers.professional_request_update</field>
        <field name="arch" type="xml">
            <form string="Solicitud de Actualización" duplicate="false" create="false">
                <header>

                    <button name="process" string="En Proceso" type="object"
                            attrs="{'invisible': [('states', '!=', 1)]}"/>
                    <button name="send_email" string="Generar Correo" type="object"
                            attrs="{'invisible': [('states', '!=', 2)]}"/>
                    <button name="validation" string="En Validación" type="object"
                            attrs="{'invisible': [('states', '!=', 2)]}"
                            groups="!security.group_professional_client_online"/>
                    <button name="approved" string="Aprobar" type="object"
                            attrs="{'invisible': [('states', '!=', 3)]}"
                            groups="!security.group_professional_client_online"/>
                    <button name="denied" string="Denegar" type="object"
                            attrs="{'invisible': [('states', '!=', 3)]}"
                            class="btn-danger"
                            groups="!security.group_professional_client_online"/>
                    <field name="states" widget="statusbar" readonly="1"/>
                </header>
                <sheet>
                    <!--                    <div class="oe_button_box" name="button_box">-->
                    <!--                        <button name="go_to_original_request" type="object"-->
                    <!--                                class="oe_stat_button" icon="fa-archive" string="Solicitud Original"-->
                    <!--                                attrs="{'invisible': [('update_type', '=', 'profile')]}">-->

                    <!--                        </button>-->
                    <!--                        <button name="view_profile" type="object"-->
                    <!--                                class="oe_stat_button" icon="fa-user" string="Perfil">-->

                    <!--                        </button>-->
                    <!--                    </div>-->


                    <field name="related_image"
                           widget="image"
                           class="oe_avatar"
                           options="{'preview_image': 'image'}"
                           required="1"/>

                    <div class="oe_title">
                        <label for="full_name" string="Nombre y apellidos"/>
                        <h1>
                            <field name="full_name" placeholder="Nombre y apellidos" required="1" readonly="1"
                                   force_save="1"/>
                        </h1>
                    </div>
                    <h3>
                        <field name="id_fuc" readonly="1"/>
                        <span>|</span>
                        <field name="request_number" readonly="1"/>
                        <field name="priority" readonly="1"/>
                    </h3>

                    <group>
                        <group>
                            <field name="original_request_id" readonly="1"
                                   options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                            <field name="profile_id" readonly="1"
                                   options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                            <!--                            <field name="update_type" widget="radio" readonly="1"/>-->
                            <field name="date_request" readonly="1"/>
                            <field name="user_id" readonly="1"
                                   options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>


                        </group>
                        <group>
                            <field name="states" readonly="1"
                                   options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                            <!--                            <field name="priority" readonly="1"/>-->
                        </group>
                    </group>
                    <notebook>
                        <!-- Pestaña de Datos Personales -->
                        <page string="Datos Personales">
                            <group>
                                <group string="Información Personal">
                                    <field name="name" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="first_last_name"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                    />
                                    <field name="second_last_name"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                    />
                                    <field name="full_name" readonly="1"/>
                                    <field name="nationality_id"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                           options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                                    <field name="identity"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="sex"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                           options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>

                                </group>
                                <group string="Información de Contacto">

                                    <field name="address" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="country" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                           options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                                    <field name="country_states"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                           options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"
                                    />
                                    <field name="city" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                           options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                                    <field name="phone" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="email" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="image" widget="image"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                </group>

                            </group>
                        </page>

                        <!-- Pestaña de Datos Académicos -->
                        <page string="Datos Académicos y Profesionales"
                        >
                            <group>
                                <group string="Formación Académica">
                                    <field name="teaching_level"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                           options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"
                                    />
                                    <field name="study_center"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                           options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"
                                    />
                                    <field name="degree_date"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="volume" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="folio" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="number" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="convalidation_degree_tittle"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                    />
                                    <field name="profession" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                           options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                                    <field name="specialties" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                           options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                                </group>
                                <group string="Investigación">
                                    <field name="investigations"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                    />
                                    <field name="investigations_year"
                                           attrs="{ 'invisible': [('investigations', '=', False)], 'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                </group>
                                <group string="Categoría Científica">
                                    <field name="degree_sciences"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                    />
                                    <field name="degree_sciences_year"
                                           attrs="{'invisible': [('degree_sciences', '=', 'anything')], 'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                </group>
                                <group string="Categoría Docente">
                                    <field name="teaching_category"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                    />
                                    <field name="teaching_category_date"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                    />
                                    <field name="unaicc_date"
                                           attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                </group>
                            </group>
                        </page>

                        <!-- Pestaña de Datos Laborales -->
                        <page string="Datos Laborales">
                            <group>
                                <group string="Situación Laboral">
                                    <field name="retired" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>
                                    <field name="date"
                                           attrs="{'invisible': [('retired', '=', False)], 'required': [('retired', '=', True)]}"/>
                                </group>
                            </group>
                            <group string="Trayectoria Laboral">
                                <field name="history_work" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}">
                                    <tree editable="bottom">
                                        <field name="work_center"/>
                                        <field name="organism"/>
                                        <field name="activity"/>
                                        <field name="phone"/>
                                        <field name="date_from"/>
                                        <field name="date_to"/>
                                    </tree>
                                </field>
                            </group>
                            <group string="Idiomas">
                                <field name="professional_language"
                                       attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}">
                                    <tree editable="bottom">
                                        <field name="language"/>
                                        <field name="proficiency_level"/>
                                    </tree>
                                </field>
                            </group>
                        </page>

                        <!-- Pestaña de Documentación -->
                        <page string="Documentos Adjuntos Originales">
                            <field name="documents_required">
                                <tree editable="bottom">
                                    <field name="documents" readonly="1" force_save="1"/>
                                    <field name="checked" string="Actualizar"/>
                                    <field name="attachment_ids" widget="many2many_binary" string="Adjunto"/>
                                    <field name="commet" string="Observaciones"/>
                                </tree>
                            </field>
                            <div class="alert alert-info" role="alert" style="margin-top:10px;">
                                <strong>Nota:</strong>
                                Solo los documentos marcados como "Personales" (CI, Currículum)
                                se actualizarán en todas sus solicitudes. Los demás son exclusivos de esta
                                actualización.
                            </div>
                        </page>

                        <!-- Pestaña de Documentación -->
                        <page string="Documentación Requerida*">
                            <group>
                                <field name="attachment_ids" widget="many2many_binary" string="Documentos adjuntos"
                                       required="1" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"/>

                            </group>


                        </page>

                        <!-- Pestaña de Historial -->
                        <page string="Historial de Estados">
                            <field name="history_ids" readonly="1">
                                <tree>
                                    <field name="date"/>
                                    <field name="state_id"/>
                                    <field name="user_id"/>
                                    <field name="observation"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Pestaña de Observaciones -->
                        <page string="Observaciones">
                            <group>
                                <field name="observation" attrs="{'readonly': [  ('priority', 'not in', (1, 2  ))]}"
                                       placeholder="Ingrese observaciones sobre la solicitud de actualización..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <!--                <div class="oe_chatter">-->
                <!--                    <field name="message_follower_ids" widget="mail_followers"/>-->
                <!--                    <field name="message_ids" widget="mail_thread"/>-->
                <!--                </div>-->
            </form>
        </field>
    </record>

    <!-- Vista de árbol -->
    <record id="view_professional_request_update_tree" model="ir.ui.view">
        <field name="name">professional.request.update.tree</field>
        <field name="model">professional_registers.professional_request_update</field>
        <field name="arch" type="xml">
            <tree string="Solicitudes de Actualización" create="false">
                <field name="request_number"/>
                <field name="original_request_id" invisible="1"/>
                <field name="profile_id" invisible="1"/>
                <field name="full_name"/>
                <field name="identity"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <!--                <field name="update_type"/>-->
                <field name="user_id"/>
                <field name="states"/>
            </tree>
        </field>
    </record>

    <!-- Vista de búsqueda -->
    <record id="view_professional_request_update_search" model="ir.ui.view">
        <field name="name">professional.request.update.search</field>
        <field name="model">professional_registers.professional_request_update</field>
        <field name="arch" type="xml">
            <search string="Buscar Solicitudes de Actualización">
                <field name="request_number"/>
                <field name="original_request_id"/>
                <field name="profile_id"/>
                <field name="full_name"/>
                <field name="identity"/>
                <field name="states"/>
                <field name="user_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <separator/>
                <filter name="my_requests" string="Mis solicitudes" domain="[('user_id', '=', uid)]"/>
                <filter name="pending" string="Pendientes" domain="[('states', 'in', [1,2,3])]"/>
                <filter name="approved" string="Aprobadas" domain="[('states', '=', 6)]"/>
                <filter name="denied" string="Denegadas" domain="[('states', '=', 8)]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_by_state" string="Estado" context="{'group_by': 'states'}"/>
                    <filter name="group_by_user" string="Usuario" context="{'group_by': 'user_id'}"/>
                    <filter name="group_by_date" string="Fecha" context="{'group_by': 'date_request'}"/>
                    <filter name="group_by_original" string="Solicitud Original"
                            context="{'group_by': 'original_request_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_professional_request_update" model="ir.actions.act_window">
        <field name="name">Solicitudes de Actualización</field>
        <field name="res_model">professional_registers.professional_request_update</field>
        <field name="view_mode">tree,form</field>
        <!--      <field name="context">{'search_default_my_requests': 1}</field>-->
        <!--        <field name="help" type="html">-->
        <!--            <p class="o_view_nocontent_smiling_face">-->
        <!--                Crear una nueva solicitud de actualización-->
        <!--            </p>-->
        <!--            <p>-->
        <!--                Para crear una solicitud de actualización, primero debe seleccionar una solicitud de inscripción-->
        <!--                existente.-->
        <!--            </p>-->
        <!--        </field>-->
    </record>

    <!-- Wizard de seleccion de tipo de actualizacion -->
    <record id="view_professional_update_request_wizard_form" model="ir.ui.view">
        <field name="name">professional.update.request.wizard.form</field>
        <field name="model">professional.update.request.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear Solicitud de Actualización">
                <group>
                    <field name="profile_id" readonly="1"/>
                    <field name="identity_filter" readonly="1"/>

                    <!--                    <field name="update_type"/>-->

                    <div class="o_horizontal_separator"></div>
                    <field name="selected_request_id"
                           required="1"
                           context="{'tree_view_ref': 'professional_registers.view_professional_request_dropdown_tree'}"/>
                </group>


                <footer>
                    <button name="create_update_request" string="Crear" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_professional_request_update" model="ir.actions.act_window">
        <field name="name">Solicitudes de Actualización</field>
        <field name="res_model">professional_registers.professional_request_update</field>
        <field name="view_mode">tree,form</field>
        <!--      <field name="context">{'search_default_my_requests': 1}</field>-->
        <!--        <field name="help" type="html">-->
        <!--            <p class="o_view_nocontent_smiling_face">-->
        <!--                Crear una nueva solicitud de actualización-->
        <!--            </p>-->
        <!--            <p>-->
        <!--                Para crear una solicitud de actualización, primero debe seleccionar una solicitud de inscripción-->
        <!--                existente.-->
        <!--            </p>-->
        <!--        </field>-->
    </record>

    <record id="sequence_professional_request_update" model="ir.sequence">
        <field name="name">Secuencia de Solicitud de Actualización</field>
        <field name="code">professional.request.update</field>
        <field name="prefix">UPD</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
