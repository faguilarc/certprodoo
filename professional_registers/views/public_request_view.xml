<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_public_request_form" model="ir.ui.view">
            <field name="name">public.request.form</field>
            <field name="model">professional_registers.public_request</field>
            <field name="arch" type="xml">
                <form string="Solicitud Pública">
                    <sheet>
                        <group>
                            <group string="Datos Personales">
                                <field name="show_name" widget="boolean_toggle"/>
                                <field name="show_first_last_name" widget="boolean_toggle"/>
                                <field name="show_second_last_name" widget="boolean_toggle"/>
                                <field name="show_sex" widget="boolean_toggle"/>
                                <field name="show_nationality_id" widget="boolean_toggle"/>
                                <field name="show_identity" widget="boolean_toggle"/>
                                <field name="show_image" widget="boolean_toggle"/>
                            </group>
                            <group string="Datos de Contacto">
                                <field name="show_phone" widget="boolean_toggle"/>
                                <field name="show_email" widget="boolean_toggle"/>
                                <field name="show_address" widget="boolean_toggle"/>
                                <field name="show_country" widget="boolean_toggle"/>
                                <field name="show_country_states" widget="boolean_toggle"/>
                                <field name="show_city" widget="boolean_toggle"/>
                            </group>
                        </group>
                        <group>
                            <group string="Datos Académicos">
                                <field name="show_teaching_level" widget="boolean_toggle"/>
                                <field name="show_study_center" widget="boolean_toggle"/>
                                <field name="show_degree_date" widget="boolean_toggle"/>
                                <field name="show_volume" widget="boolean_toggle"/>
                                <field name="show_folio" widget="boolean_toggle"/>
                                <field name="show_number" widget="boolean_toggle"/>
                            </group>
                            <group string="Datos Profesionales">
                                <field name="show_profession" widget="boolean_toggle"/>
                                <field name="show_specialties" widget="boolean_toggle"/>
                                <field name="show_teaching_category" widget="boolean_toggle"/>
                                <field name="show_teaching_category_date" widget="boolean_toggle"/>
                                <field name="show_degree_sciences" widget="boolean_toggle"/>
                                <field name="show_degree_sciences_year" widget="boolean_toggle"/>
                                <field name="show_unaicc_date" widget="boolean_toggle"/>
                            </group>
                        </group>
                        <group string="Vínculo e Idiomas">
                            <field name="show_history_work" widget="boolean_toggle"/>
                            <field name="show_professional_language" widget="boolean_toggle"/>
                        </group>
                        <group string="Documentos Requeridos">
                            <field name="show_required_documents" widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_public_request_tree" model="ir.ui.view">
            <field name="name">public.request.tree</field>
            <field name="model">professional_registers.public_request</field>
            <field name="arch" type="xml">
                <tree string="Solicitudes Públicas">
                    <field name="show_name"/>
                    <field name="show_first_last_name"/>
                    <field name="show_second_last_name"/>
                    <field name="show_nationality_id"/>
                    <field name="show_identity"/>
                    <field name="show_sex"/>
                    <field name="show_phone"/>
                    <field name="show_email"/>
                    <field name="show_country"/>
                    <field name="show_teaching_level"/>
                    <field name="show_study_center"/>
                    <field name="show_profession"/>
                    <field name="show_specialties"/>
                    <field name="show_history_work"/>
                </tree>
            </field>
        </record>


        <record id="action_public_request" model="ir.actions.act_window">
            <field name="name">Campos Públicos</field>
            <field name="res_model">professional_registers.public_request</field>
            <field name="view_mode">tree,form</field>
            <field name="target">new</field>
            <field name="context">{'create': False}</field>
            <field name="domain">[('request_id', '=', active_id)]</field>
        </record>

<!--        <menuitem id="menu_public_request"-->
<!--                  name="Campos Públicos"-->
<!--                  parent="professional_function_menu"-->
<!--                  action="action_public_request"-->
<!--                  sequence="20"/>-->
    </data>
</odoo>