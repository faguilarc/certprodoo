<?xml version="1.0" encoding="UTF-8"?>
<templates id="dashboard_templates" xml:space="preserve">
    <t t-name="DashboardDetails">
        <div class="container-fluid certprodoo-dashboard">

            <!-- Loading Spinner -->
            <div class="loading-spinner d-none text-center py-5">
                <i class="fa fa-spinner fa-spin fa-2x text-primary"/>
                <span class="ml-2">Cargando datos...</span>
            </div>

            <!-- Dashboard Content -->
            <div class="dashboard-content">

                <!-- Header con selector de periodo -->
                <div class="row mb-3">
                    <div class="col-12 col-md-6">
                        <h3 class="dashboard-title">
                            <i class="fa fa-tachometer"/> Cuadro de Mando
                        </h3>
                    </div>
                    <div class="col-12 col-md-6 text-md-right">
                        <div class="period-filter">
                            <label class="mr-2 font-weight-bold">Periodo:</label>
                            <select class="period-selector form-control form-control-sm d-inline-block" style="width: auto;">
                                <option value="month">Este Mes</option>
                                <option value="quarter">Este Trimestre</option>
                                <option value="year" selected="selected">Este Ano</option>
                                <option value="all">Todo</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- ============================================================ -->
                <!-- KPI CARDS -->
                <!-- ============================================================ -->
                <div class="row mb-4">
                    <div class="col-6 col-md-4 col-lg mb-3">
                        <div class="kpi-card kpi-blue" id="kpiTotalRequests" data-target="total_requests">
                            <div class="kpi-icon"><i class="fa fa-file-text-o"/></div>
                            <div class="kpi-info">
                                <div class="kpi-value">0</div>
                                <div class="kpi-label">Solicitudes</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg mb-3">
                        <div class="kpi-card kpi-green" id="kpiApprovedRequests" data-target="approved_requests">
                            <div class="kpi-icon"><i class="fa fa-check-circle"/></div>
                            <div class="kpi-info">
                                <div class="kpi-value">0</div>
                                <div class="kpi-label">Aprobadas</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg mb-3">
                        <div class="kpi-card kpi-orange" id="kpiPendingRequests" data-target="pending_requests">
                            <div class="kpi-icon"><i class="fa fa-hourglass-half"/></div>
                            <div class="kpi-info">
                                <div class="kpi-value">0</div>
                                <div class="kpi-label">Pendientes</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg mb-3">
                        <div class="kpi-card kpi-teal" id="kpiInscriptions" data-target="inscriptions">
                            <div class="kpi-icon"><i class="fa fa-id-card-o"/></div>
                            <div class="kpi-info">
                                <div class="kpi-value">0</div>
                                <div class="kpi-label">Inscripciones</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg mb-3">
                        <div class="kpi-card kpi-purple" id="kpiExpedients" data-target="expedients">
                            <div class="kpi-icon"><i class="fa fa-folder-open-o"/></div>
                            <div class="kpi-info">
                                <div class="kpi-value">0</div>
                                <div class="kpi-label">Expedientes</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg mb-3">
                        <div class="kpi-card kpi-red" id="kpiClaims" data-target="claims">
                            <div class="kpi-icon"><i class="fa fa-exclamation-triangle"/></div>
                            <div class="kpi-info">
                                <div class="kpi-value">0</div>
                                <div class="kpi-label">Reclamaciones</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg mb-3">
                        <div class="kpi-card kpi-gray" id="kpiAvgTime">
                            <div class="kpi-icon"><i class="fa fa-clock-o"/></div>
                            <div class="kpi-info">
                                <div class="kpi-value">0</div>
                                <div class="kpi-label">Dias Promedio</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ============================================================ -->
                <!-- SOLICITUDES POR ESTADO - Cards + Chart Toggle -->
                <!-- ============================================================ -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="dash-card">
                            <div class="dash-card-header d-flex justify-content-between align-items-center">
                                <h4><i class="fa fa-bar-chart"/> Solicitudes por Estado</h4>
                                <div class="btn-group btn-group-sm" role="group">
                                    <button type="button" class="btn btn-outline-secondary active" id="btnCardView">
                                        <i class="fa fa-th-large"/> Tarjetas
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" id="btnChartView">
                                        <i class="fa fa-pie-chart"/> Grafico
                                    </button>
                                </div>
                            </div>
                            <div class="dash-card-body">
                                <!-- Card View -->
                                <div id="cardView">
                                    <div class="row">
                                        <t t-foreach="widget.dashboard_data.solicitudes_estado or []" t-as="estado">
                                            <div class="col-6 col-sm-4 col-md-3 col-lg mb-3">
                                                <div class="status-card" t-att-data-estado="estado.state_id"
                                                     t-attf-style="border-left: 4px solid #{estado.color};">
                                                    <div class="status-card-body">
                                                        <div class="status-count">
                                                            <t t-esc="estado.cantidad"/>
                                                        </div>
                                                        <div class="status-name">
                                                            <t t-esc="estado.state_name"/>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                                <!-- Chart View -->
                                <div id="chartView" style="display: none;">
                                    <div class="chart-container" style="height: 350px;">
                                        <canvas id="chartSolicitudesEstado"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ============================================================ -->
                <!-- TENDENCIA MENSUAL + TOP PROFESIONES -->
                <!-- ============================================================ -->
                <div class="row mb-4">
                    <div class="col-12 col-lg-7 mb-3">
                        <div class="dash-card">
                            <div class="dash-card-header">
                                <h4><i class="fa fa-line-chart"/> Tendencia Mensual</h4>
                            </div>
                            <div class="dash-card-body">
                                <div class="chart-container" style="height: 300px;">
                                    <canvas id="chartTendenciaMensual"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-5 mb-3">
                        <div class="dash-card">
                            <div class="dash-card-header">
                                <h4><i class="fa fa-trophy"/> Top 10 Profesiones</h4>
                            </div>
                            <div class="dash-card-body">
                                <div class="chart-container" style="height: 300px;">
                                    <canvas id="chartTopProfesiones"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ============================================================ -->
                <!-- TIPO DE TRAMITE + RECLAMACIONES -->
                <!-- ============================================================ -->
                <div class="row mb-4">
                    <div class="col-12 col-lg-6 mb-3">
                        <div class="dash-card">
                            <div class="dash-card-header">
                                <h4><i class="fa fa-list-alt"/> Por Tipo de Tramite</h4>
                            </div>
                            <div class="dash-card-body">
                                <div class="chart-container" style="height: 280px;">
                                    <canvas id="chartTipoTramite"/>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 mb-3">
                        <div class="dash-card">
                            <div class="dash-card-header">
                                <h4><i class="fa fa-gavel"/> Reclamaciones por Estado</h4>
                            </div>
                            <div class="dash-card-body">
                                <div class="chart-container" style="height: 280px;">
                                    <canvas id="chartReclamaciones"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ============================================================ -->
                <!-- TASAS DE APROBACION / RECHAZO -->
                <!-- ============================================================ -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="dash-card">
                            <div class="dash-card-header d-flex justify-content-between align-items-center">
                                <h4><i class="fa fa-check-square"/> Tasa de Aprobacion / Rechazo por Tipo de Tramite</h4>
                                <div class="tasa-summary" t-if="widget.dashboard_data.tasas">
                                    <span class="badge badge-success mr-2">
                                        Aprobacion: <t t-esc="widget.dashboard_data.tasas.tasa_aprobacion_global"/>%
                                    </span>
                                    <span class="badge badge-danger">
                                        Rechazo: <t t-esc="widget.dashboard_data.tasas.tasa_rechazo_global"/>%
                                    </span>
                                </div>
                            </div>
                            <div class="dash-card-body">
                                <div class="chart-container" style="height: 300px;">
                                    <canvas id="chartTasas"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!-- /dashboard-content -->
        </div><!-- /certprodoo-dashboard -->
    </t>
</templates>
