<odoo>
    <data>
        <!-- Client Action: Dashboard Principal -->
        <record id="action_dashboard" model="ir.actions.client">
            <field name="name">Cuadro de Mando</field>
            <field name="tag">dashboard.dashboard</field>
        </record>

        <!-- Client Action: Dashboard Cliente -->
        <record id="action_dashboard_client" model="ir.actions.client">
            <field name="name">Terminos y Condiciones</field>
            <field name="tag">dashboard.dashboard_client</field>
        </record>

        <!-- Menu: Cuadro de Mando (visible para roles internos) -->
        <menuitem
            id="menu_root_dashboard_page"
            name="Cuadro de Mando"
            action="action_dashboard"
            groups="security.group_professional_superadmin,security.group_professional_consultant,security.group_professional_editor_managment,security.group_professional_reigster_managment"
            sequence="-1"
            web_icon="dashboard/static/description/icon.png"/>

        <!-- Menu: Terminos y Condiciones (visible para clientes y registrador) -->
        <menuitem
            id="menu_root_dashboard_client_page"
            name="Terminos y Condiciones"
            action="action_dashboard_client"
            groups="security.group_professional_client,security.group_professional_client_online,security.group_professional_register_employee"
            sequence="-1"
            web_icon="dashboard/static/description/icon.png"/>
    </data>
</odoo>
