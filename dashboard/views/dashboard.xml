<odoo>
  <data>
      <record id="action_dashboard" model="ir.actions.client">
                <field name="name">Estadísticas</field>
                <field name="tag">dashboard.dashboard</field>
            </record>
      <record id="action_dashboard_client" model="ir.actions.client">
                <field name="name">Estadísticas</field>
                <field name="tag">dashboard.dashboard_client</field>
            </record>
            <menuitem
                    id="menu_root_dashboard_page"
                    name="Cuadro de Mando"
                    action="action_dashboard"
                    groups="base.group_erp_manager,security.group_professional_consultant"
                    sequence="-1" web_icon="dashboard/static/description/icon.png"/>
            <menuitem
                    id="menu_root_dashboard_client_page"
                    name="Términos y condiciones"
                    action="action_dashboard_client"
                    groups="security.group_professional_client,security.group_professional_client_online,security.group_professional_register_employee"
                    sequence="-1" web_icon="dashboard/static/description/icon.png"/>

  </data>
</odoo>