<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="conection_test_view" model="ir.ui.view">
            <field name="name">Conexión a BD</field>
            <field name="model">conection.conection</field>
            <field name="arch" type="xml">
                <form string="Conexión a BD">
                    <sheet>
                        <div class="oe_form_container">
                            <div class="oe_form_sheet">
                                <div class="sol_serv">
                                    <div class="oe_button_box" name="button_box">
                                        <button type="object" name="extraer_datos" class="btn oe_stat_button"
                                                style="width:145px !important;">
                                            <i class="fa fa-fw o_button_icon fa-print"></i>
                                            <span>Ejecutar Script</span>
                                        </button>
                                    </div>
                                </div>
                                <group>
                                    <field name="script_type" class="w-25" required="1" widget="radio"/>
                                </group>
                                <group>
                                    <field name="date_inscription" class="w-25" attrs="{'required': [('script_type', '=', 'sell_tickets')], 'invisible': [('script_type', '!=', 'sell_tickets')]}"/>
                                </group>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="conection_test_tree" model="ir.ui.view">
            <field name="name">Conexión a BD</field>
            <field name="model">conection.conection</field>
            <field name="arch" type="xml">
                <tree string="Conexión a BD">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record id="conection_test_action_windows" model="ir.actions.act_window">
            <field name="name">Conexión a BD</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">conection.conection</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aqui puede probar la conexión con otras Base de datos
                </p>
            </field>
        </record>
    </data>
</odoo>