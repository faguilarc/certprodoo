<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_documents_required">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <style>
                        .table > thead > tr > th,
                        .table > tbody > tr > th,
                        .table > tfoot > tr > th,
                        .table > thead > tr > td,
                        .table > tbody > tr > td,
                        .table > tfoot > tr > td {
                            padding: 0 10px;
                            text-align: left;
                            font-size: 0.8em !important;
                        }
                        .body{
                            font-size: 0.8em !important;
                        }
                        .pie{
                            font-size: 0.8em !important;
                        }
                        .encabezado{font-size: 0.10em !important;}
                        .sepdiv{margin-top: 20px;}
                       .page {page-break-after: always;}
                        .cliente1{
                        border-width: 2px;
                        border-style: groove;
                        border-color: #ffffff;
                        border-image: initial;
                        display: block;
                        padding-block-start: 0.1em;
                        padding-inline-start: 0.5em;
                        padding-inline-end: 0.15em;
                        padding-block-end: 0.325em;
                        min-inline-size: min-content;
                        -moz-border-radius:2px;
                        -webkit-border-radius:2px;
                        border-radius:2px;
                        padding: 2px 5px;
                    }
                        </style>
                    <div class="page">
                        <center><h4>Documentación requerida para trámite <t t-esc="procedure_type"/></h4></center>
                        <div class="row sepdiv body">
                            <table class="table">
                                <thead>
                                    <th>No.</th>
                                    <th>Documento</th>
                                    <th>Descripción</th>
                                </thead>
                                <tbody>
                                     <t t-foreach="documents" t-as="line">
                                         <tr>
                                             <td>
                                                 <span t-esc="line['no']"/>
                                             </td>
                                            <td>
                                                <span t-esc="line['name']"/>
                                            </td>
                                             <td>
                                                <span t-esc="line['description']"/>
                                            </td>
                                        </tr>
                                     </t>
                                </tbody>
                            </table>
                        </div>
                        <footer></footer>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>