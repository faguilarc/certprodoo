<?xml version="1.0" encoding="UTF-8"?>
<templates id="Dashboard" xml:space="preserve">
    <t t-name="DashboardNomenclatorDetails">
        <div class="row main-section o_dashboard" >
            <div class="col-md-3 col-sm-6 profession oh-payslip" >
                <div class="oh-card">
                    <div class="oh-card-body">
                        <div class="stat-widget-one">
                            <div class="stat-icon"><i class="fa fa-graduation-cap"/></div>
                            <div class="stat-content">
                                <div class="stat-text"><h3>Profesiones</h3></div>
                                <div class="stat-digit"><strong ><t t-esc="widget.users_info['professions']"/></strong></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 specialties oh-payslip" >
                <div class="oh-card">
                    <div class="oh-card-body">
                        <div class="stat-widget-one">
                            <div class="stat-icon"><i class="fa fa-tasks"/></div>
                            <div class="stat-content">
                                <div class="stat-text"><h3>Especialidades</h3></div>
                                <div class="stat-digit"><strong ><t t-esc="widget.users_info['specialities']"/></strong></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3 col-sm-6 study_center oh-payslip" >
                <div class="oh-card">
                    <div class="oh-card-body">
                        <div class="stat-widget-one">
                            <div class="stat-icon"><i class="fa fa-university"/></div>
                            <div class="stat-content">
                                <div class="stat-text"><h3>Centros de Estudio</h3></div>
                                <div class="stat-digit"><strong ><t t-esc="widget.users_info['college']"/></strong></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-sm-6 teaching_categories oh-payslip" >
                <div class="oh-card">
                    <div class="oh-card-body">
                        <div class="stat-widget-one">
                            <div class="stat-icon"><i class="fa fa-th-list"/></div>
                            <div class="stat-content">
                                <div class="stat-text"><h3>Categorías Docentes</h3></div>
                                <div class="stat-digit"><strong ><t t-esc="widget.users_info['categories']"/></strong></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-sm-6 documents_required oh-payslip" >
                <div class="oh-card">
                    <div class="oh-card-body">
                        <div class="stat-widget-one">
                            <div class="stat-icon"><i class="fa fa-file"/></div>
                            <div class="stat-content">
                                <div class="stat-text"><h3>Documentos para Inscripción</h3></div>
                                <div class="stat-digit"><strong ><t t-esc="widget.users_info['documents_inscriptions']"/></strong></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
