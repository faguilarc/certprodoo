<odoo>
    <data>
        <record id="labour_sector_form_view" model="ir.ui.view">
            <field name="name">nomenclators.labour_sector.form</field>
            <field name="model">nomenclators.labour_sector</field>
            <field name="arch" type="xml">
                <form string="Tipo de Entidad" duplicate="false">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Nombre" required="1"/>
                            </h1>
                        </div>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="labour_sector_tree_view" model="ir.ui.view">
            <field name="name">nomenclators.labour_sector.tree</field>
            <field name="model">nomenclators.labour_sector</field>
            <field name="arch" type="xml">
                <tree string="Tipo de Entidad">
                    <field name="name"/>

                </tree>
            </field>
        </record>

        <record id="labour_sector_search_view" model="ir.ui.view">
            <field name="name">nomenclators.labour_sector.search</field>
            <field name="model">nomenclators.labour_sector</field>
            <field name="arch" type="xml">
                <search string="Tipo de Entidad">
                    <field name="name" string="Tipo de entidad"/>
                </search>
            </field>
        </record>

        <record id="labour_sector_act_window" model="ir.actions.act_window">
            <field name="name">Tipo de Entidad</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nomenclators.labour_sector</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede adicionar un nuevo tipo de entidad
                </p>
            </field>
        </record>
    </data>
</odoo>