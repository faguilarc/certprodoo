<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="country_inherit_form">
            <field name="name">País</field>
            <field name="model">res.country</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="País" duplicate="false">
                    <sheet>
                        <div class="oe_form_container">
                            <div class="oe_form_sheet">
                                <group col="4">
                                    <field name="name"/>
                                    <field name="code" string="Siglas"/>
                                    <field name="currency_id"/>
                                    <field name="country_code"/>
                                </group>
                                <group>
                                    <notebook>
                                        <page string="Estados">
                                            <field name="state_ids">
                                                <tree class="tree_no_open" editable="bootom">
                                                    <field name="name"/>
                                                    <field name="code"/>
                                                </tree>
                                            </field>
                                        </page>
                                    </notebook>
                                </group>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="country_inherit_tree">
            <field name="name">País</field>
            <field name="model">res.country</field>
            <field name="type">tree</field>
            <field name="arch" type="xml">
                <tree string="País">
                    <field name="name"/>
                    <field name="code" string="Siglas"/>
                    <field name="country_code"/>
                </tree>
            </field>
        </record>

        <record id="country_inherit_action" model="ir.actions.act_window">
            <field name="name">País</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.country</field>
            <field name="view_mode">tree,form</field>
            <field name="view_ids" eval="[(5,0,0), (0,0,{'view_mode': 'tree', 'view_id': ref('country_inherit_tree')}), (0,0,{'view_mode': 'form', 'view_id': ref('country_inherit_form')})]"/>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede registrar una nuevo país
                </p>
            </field>
        </record>
    </data>
</odoo>