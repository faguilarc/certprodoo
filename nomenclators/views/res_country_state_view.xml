<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="country_state_inherit_action" model="ir.actions.act_window">
            <field name="name">Provincia</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.country.state</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede registrar una nueva provincia
                </p>
            </field>
        </record>
        <record id="country_state_inherit_search" model="ir.ui.view">
            <field name="name">res.bank.search</field>
            <field name="model">res.country.state</field>
            <field name="inherit_id" ref="base.view_country_state_search"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="code"/>
                </field>
            </field>
        </record>
    </data>
</odoo>