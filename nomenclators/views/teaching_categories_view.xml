<odoo>
    <data>
        <record id="teaching_categories_form_view" model="ir.ui.view">
            <field name="name">nomenclators.teaching_categories.form</field>
            <field name="model">nomenclators.teaching_categories</field>
            <field name="arch" type="xml">
                <form string="Categoría docente" duplicate="false">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Nombre" required="1"/>
                            </h1>
                        </div>
                        <notebook>
                            <page string="Descripción">
                                <field name="description" required="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="teaching_categories_tree_view" model="ir.ui.view">
            <field name="name">nomenclators.teaching_categories.tree</field>
            <field name="model">nomenclators.teaching_categories</field>
            <field name="arch" type="xml">
                <tree string="Categoría docente">
                    <field name="name"/>
                    <field name="description"/>
                </tree>
            </field>
        </record>

        <record id="teaching_categories_search_view" model="ir.ui.view">
            <field name="name">nomenclators.teaching_categories.search</field>
            <field name="model">nomenclators.teaching_categories</field>
            <field name="arch" type="xml">
                <search string="Categoría docente">
                    <field name="name" string="Categoría"/>
                </search>
            </field>
        </record>

        <record id="teaching_categories_act_window" model="ir.actions.act_window">
            <field name="name">Categoría docente</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nomenclators.teaching_categories</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede adicionar una nueva categoría
                </p>
            </field>
        </record>
    </data>
</odoo>