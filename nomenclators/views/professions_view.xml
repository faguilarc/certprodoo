<odoo>
    <data>
        <record id="professions_form_view" model="ir.ui.view">
            <field name="name">nomenclators.professions.form</field>
            <field name="model">nomenclators.professions</field>
            <field name="arch" type="xml">
                <form string="Profesiones" duplicate="false">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Nombre" required="1"/>
                            </h1>
                        </div>
                        <notebook>
                            <page string="Descripción">
                                <field name="description" required="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="professions_tree_view" model="ir.ui.view">
            <field name="name">nomenclators.professions.tree</field>
            <field name="model">nomenclators.professions</field>
            <field name="arch" type="xml">
                <tree string="Profesiones">
                    <field name="name"/>
                    <field name="description"/>
                </tree>
            </field>
        </record>

        <record id="professions_search_view" model="ir.ui.view">
            <field name="name">nomenclators.professions.search</field>
            <field name="model">nomenclators.professions</field>
            <field name="arch" type="xml">
                <search string="Profesiones">
                    <field name="name" string="Profesión"/>
                </search>
            </field>
        </record>

        <record id="professions_act_window" model="ir.actions.act_window">
            <field name="name">Profesiones</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nomenclators.professions</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede adicionar una nueva profesión
                </p>
            </field>
        </record>
    </data>
</odoo>