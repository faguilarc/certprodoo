<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="logo_form_view" model="ir.ui.view">
            <field name="name">Logo</field>
            <field name="model">nomenclators.logo</field>
            <field name="arch" type="xml">
                <form string="Logo">
                    <sheet>
                        <div class="oe_form_container">
                            <div class="oe_form_sheet">
                                <field name="image" widget="image" class="oe_avatar"/>
                                <div class="oe_title">
                                    <label class="oe_edit_only" for="name" string="Nombre"/>
                                    <h1><field name="name" placeholder="Nombre del logo"/></h1>
                                </div>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="logo_tree" model="ir.ui.view">
            <field name="name">Logo</field>
            <field name="model">nomenclators.logo</field>
            <field name="arch" type="xml">
                <tree string="Logo">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record id="logo_search" model="ir.ui.view">
            <field name="name">Logo</field>
            <field name="model">nomenclators.logo</field>
            <field name="arch" type="xml">
                <search string="Logo">
                    <field name="name"/>
                </search>
            </field>
        </record>

        <record id="logo_act_windows" model="ir.actions.act_window">
            <field name="name">Logo</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nomenclators.logo</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede adicionar un logo para los reportes
                </p>
            </field>
        </record>
    </data>
</odoo>