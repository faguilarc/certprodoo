<odoo>
    <data>
        <record id="documents_required_form_view" model="ir.ui.view">
            <field name="name">nomenclators.documents_required.form</field>
            <field name="model">nomenclators.documents_required</field>
            <field name="arch" type="xml">
                <form string="Documentos requeridos por trámite" duplicate="false">
                    <sheet>
                        <header>
                            <button name="generate_carnet_zip" string="Descargar ZIP" type="object"/>
                        </header>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Nombre" required="1"/>
                            </h1>
                        </div>
                        <group col="4">
                            <field name="order" required="1"/>
                            <field name="procedure1" required="1"
                                   options="{'no_open': True, 'no_create': True, 'no_create_edit':True}"/>
                        </group>
                        <div class="row mt-3">
                            <div class="col-lg-6">
                                <label for="is_document_required" string="Documento Obligatorio"/>
                                <field name="is_document_required"/>
                            </div>
                            <div class="col-lg-6">
                                <label for="is_personal_document" string="Documento Personal"/>
                                <field name="is_personal_document"/>
                            </div>
                        </div>
                        <notebook>
                            <page string="Descripción">
                                <field name="description"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="documents_required_tree_view" model="ir.ui.view">
            <field name="name">nomenclators.documents_required.tree</field>
            <field name="model">nomenclators.documents_required</field>
            <field name="arch" type="xml">
                <tree string="Documentos requeridos por trámite">
                    <field name="name"/>
                    <field name="description"/>
                    <field name="procedure1"/>
                    <field name="order"/>
                    <field name="is_document_required"/>
                    <field name="is_personal_document"/>
                </tree>
            </field>
        </record>

        <record id="documents_required_search_view" model="ir.ui.view">
            <field name="name">nomenclators.documents_required.search</field>
            <field name="model">nomenclators.documents_required</field>
            <field name="arch" type="xml">
                <search string="Documentos requeridos por trámite">
                    <field name="name" string="Documento"/>
                    <field name="procedure1" string="Trámite"/>
                </search>
            </field>
        </record>

        <record id="documents_required_act_window" model="ir.actions.act_window">
            <field name="name">Documentos requeridos por trámite</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nomenclators.documents_required</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede adicionar una nuevo documento para un trámite determinado
                </p>
            </field>
        </record>
    </data>
</odoo>