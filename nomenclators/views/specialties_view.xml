<odoo>
    <data>
        <record id="specialties_form_view" model="ir.ui.view">
            <field name="name">nomenclators.specialties.form</field>
            <field name="model">nomenclators.specialties</field>
            <field name="arch" type="xml">
                <form string="Especialidades" duplicate="false">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Nombre" required="1"/>
                            </h1>
                        </div>
                        <group>
                            <field name="profession_id" class="w-25" options="{'no_open': True, 'no_create': True, 'no_create_edit':True}" required="1"/>
                        </group>
                        <notebook>
                            <page string="Descripción">
                                <field name="description" required="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="specialties_tree_view" model="ir.ui.view">
            <field name="name">nomenclators.specialties.tree</field>
            <field name="model">nomenclators.specialties</field>
            <field name="arch" type="xml">
                <tree string="Especialidades">
                    <field name="profession_id"/>
                    <field name="name"/>
                    <field name="description"/>
                </tree>
            </field>
        </record>

        <record id="specialties_search_view" model="ir.ui.view">
            <field name="name">nomenclators.specialties.search</field>
            <field name="model">nomenclators.specialties</field>
            <field name="arch" type="xml">
                <search string="Especialidades">
                    <field name="name" string="Especialidad"/>
                    <field name="profession_id" string="Profesión"/>
                </search>
            </field>
        </record>

        <record id="specialties_act_window" model="ir.actions.act_window">
            <field name="name">Especialidades</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nomenclators.specialties</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede adicionar una nueva especialidad
                </p>
            </field>
        </record>
    </data>
</odoo>