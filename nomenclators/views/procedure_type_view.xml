<odoo>
    <data>
        <record id="procedure_type_form_view" model="ir.ui.view">
            <field name="name">nomenclators.procedure_types.form</field>
            <field name="model">nomenclators.procedure_types</field>
            <field name="arch" type="xml">
                <form string="Tipos de trámite" duplicate="false">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Nombre" required="1"/>
                            </h1>
                        </div>
                        <group>

                            <field name="comodel_name" string="Identificador"/>
                            <field name="active" string="Activo"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="procedure_type_tree_view" model="ir.ui.view">
            <field name="name">nomenclators.procedure_types.tree</field>
            <field name="model">nomenclators.procedure_types</field>
            <field name="arch" type="xml">
                <tree string="Tipos de trámite">
                    <field name="name"/>
                    <field name="active" string="Activo"/>
                </tree>
            </field>
        </record>

        <record id="procedure_type_search_view" model="ir.ui.view">
            <field name="name">nomenclators.procedure_types.search</field>
            <field name="model">nomenclators.procedure_types</field>
            <field name="arch" type="xml">
                <search string="Tipos de trámite">
                    <field name="name" string="Trámite"/>
                </search>
            </field>
        </record>

        <record id="procedure_types_act_window" model="ir.actions.act_window">
            <field name="name">Tipos de trámite</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nomenclators.procedure_types</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede adicionar una nuevo documento tipo de trámite
                </p>
            </field>
        </record>

