<odoo>
    <template id="terms_conditions_page" name="Terms and Conditions">
        <t t-call="web.layout">
            <div class="oe_structure">
                <h1>Terms and Conditions</h1>
                <t t-foreach="docs" t-as="doc">
                    <div class="term-section">
                        <h2><t t-esc="doc.name"/></h2>
                        <div t-raw="doc.content"/>
                    </div>
                </t>
            </div>
        </t>
    </template>
</odoo>