<odoo>
    <data>
        <record id="nationality_form_view" model="ir.ui.view">
            <field name="name">nomenclators.nationality.form</field>
            <field name="model">nomenclators.nationality</field>
            <field name="arch" type="xml">
                <form string="Nacionalidades" duplicate="false">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" placeholder="Nombre" required="1"/>
                            </h1>
                        </div>
                        <group>
                            <field name="validate_fuc"/>
                            <label for="validate_fuc"
                                   string="si va a usar la nacionalidad para la FUC recuerde marcar el checkbox"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="nationality_tree_view" model="ir.ui.view">
            <field name="name">nomenclators.nationality.tree</field>
            <field name="model">nomenclators.nationality</field>
            <field name="arch" type="xml">
                <tree string="Nacionalidades">
                    <field name="name"/>
                    <field name="validate_fuc"/>
                </tree>
            </field>
        </record>

        <record id="nationality_search_view" model="ir.ui.view">
            <field name="name">nomenclators.nationality.search</field>
            <field name="model">nomenclators.nationality</field>
            <field name="arch" type="xml">
                <search string="Nacionalidades">
                    <field name="name" string="Nacionalidad"/>
                </search>
            </field>
        </record>

        <record id="nationality_act_window" model="ir.actions.act_window">
            <field name="name">Nacionalidades</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nomenclators.nationality</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Aquí puede adicionar una nueva nacionalidad
                </p>
            </field>
        </record>
    </data>
</odoo>