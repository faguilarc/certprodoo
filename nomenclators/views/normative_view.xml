<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="normative_form_view" model="ir.ui.view">
            <field name="name">nomenclators.normative.form</field>
            <field name="model">nomenclators.normative</field>
            <field name="arch" type="xml">
                <form string="Normativas" duplicate="false">
                    <sheet>
                        <notebook>
                            <page string="Normativas">
                                <field name="name" required="1"/>
                            </page>
                        </notebook>
                        <div>
                            <separator string="Subir normativas"/>
                            <group>
                                <div>
                                    <field name="attachment_ids" widget="many2many_binary"/>
                                </div>
                            </group>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="normative_tree_view" model="ir.ui.view">
            <field name="name">nomenclators.normative.tree</field>
            <field name="model">nomenclators.normative</field>
            <field name="arch" type="xml">
                <tree string="Normativas">
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record id="normative_act_window" model="ir.actions.act_window">
            <field name="name">Normativas</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">nomenclators.normative</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Normativas
                </p>
            </field>
        </record>

    </data>
</odoo>