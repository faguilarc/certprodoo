<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Vista Lista ──────────────────────────────────────── -->
    <record id="teaching_category_view_tree" model="ir.ui.view">
        <field name="name">certprodoo.teaching.category.tree</field>
        <field name="model">certprodoo.teaching.category</field>
        <field name="arch" type="xml">
            <tree string="Categorías Docentes">
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- ─── Vista Formulario ─────────────────────────────────── -->
    <record id="teaching_category_view_form" model="ir.ui.view">
        <field name="name">certprodoo.teaching.category.form</field>
        <field name="model">certprodoo.teaching.category</field>
        <field name="arch" type="xml">
            <form string="Categoría Docente">
                <header>
                    <button name="toggle_active" type="object"
                            string="Archivar" class="btn-secondary"
                            invisible="active == False"
                            groups="certprodoo_nomenclators.group_nomenclator_manager"/>
                    <button name="toggle_active" type="object"
                            string="Desarchivar" class="btn-secondary"
                            invisible="active == True"
                            groups="certprodoo_nomenclators.group_nomenclator_manager"/>
                </header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nombre de la categoría docente"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="description" placeholder="Descripción de la categoría"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ─── Acción ───────────────────────────────────────────── -->
    <record id="teaching_category_action" model="ir.actions.act_window">
        <field name="name">Categorías Docentes</field>
        <field name="res_model">certprodoo.teaching.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear una nueva categoría docente
            </p>
            <p>
                Defina las categorías docentes del sistema educativo.
            </p>
        </field>
    </record>

</odoo>
