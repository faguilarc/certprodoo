<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Vista Lista ──────────────────────────────────────── -->
    <record id="terms_conditions_view_tree" model="ir.ui.view">
        <field name="name">certprodoo.terms.conditions.tree</field>
        <field name="model">certprodoo.terms.conditions</field>
        <field name="arch" type="xml">
            <tree string="Términos y Condiciones">
                <field name="name"/>
                <field name="code"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- ─── Vista Formulario ─────────────────────────────────── -->
    <record id="terms_conditions_view_form" model="ir.ui.view">
        <field name="name">certprodoo.terms.conditions.form</field>
        <field name="model">certprodoo.terms.conditions</field>
        <field name="arch" type="xml">
            <form string="Términos y Condiciones">
                <header>
                    <button name="toggle_active" type="object"
                            string="Archivar" class="btn-secondary"
                            invisible="active == False"
                            groups="certprodoo_nomenclators.group_nomenclator_manager"/>
                    <button name="toggle_active" type="object"
                            string="Desarchivar" class="btn-secondary"
                            invisible="active == True"
                            groups="certprodoo_nomenclators.group_nomenclator_manager"/>
                </header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Título de los términos y condiciones"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group string="Contenido">
                        <field name="content" nolabel="1" colspan="2"
                               placeholder="Contenido HTML de los términos y condiciones..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ─── Acción ───────────────────────────────────────────── -->
    <record id="terms_conditions_action" model="ir.actions.act_window">
        <field name="name">Términos y Condiciones</field>
        <field name="res_model">certprodoo.terms.conditions</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear nuevos términos y condiciones
            </p>
            <p>
                Defina los términos y condiciones para el portal web del sistema.
            </p>
        </field>
    </record>

</odoo>
