<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Vista Lista ──────────────────────────────────────── -->
    <record id="teaching_level_view_tree" model="ir.ui.view">
        <field name="name">certprodoo.teaching.level.tree</field>
        <field name="model">certprodoo.teaching.level</field>
        <field name="arch" type="xml">
            <tree string="Niveles de Enseñanza">
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- ─── Vista Formulario ─────────────────────────────────── -->
    <record id="teaching_level_view_form" model="ir.ui.view">
        <field name="name">certprodoo.teaching.level.form</field>
        <field name="model">certprodoo.teaching.level</field>
        <field name="arch" type="xml">
            <form string="Nivel de Enseñanza">
                <header>
                    <button name="toggle_active" type="object"
                            string="Archivar" class="btn-secondary"
                            invisible="active == False"
                            groups="certprodoo_nomenclators.group_nomenclator_manager"/>
                    <button name="toggle_active" type="object"
                            string="Desarchivar" class="btn-secondary"
                            invisible="active == True"
                            groups="certprodoo_nomenclators.group_nomenclator_manager"/>
                </header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nombre del nivel de enseñanza"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="description" placeholder="Descripción del nivel"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Centros de Estudio" name="study_centers">
                            <field name="study_center_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ─── Acción ───────────────────────────────────────────── -->
    <record id="teaching_level_action" model="ir.actions.act_window">
        <field name="name">Niveles de Enseñanza</field>
        <field name="res_model">certprodoo.teaching.level</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo nivel de enseñanza
            </p>
            <p>
                Defina los niveles de enseñanza del sistema educativo.
            </p>
        </field>
    </record>

</odoo>
