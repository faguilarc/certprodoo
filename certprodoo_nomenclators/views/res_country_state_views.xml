<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Acción Provincias (solo Cuba) ────────────────────── -->
    <!-- O17 ya tiene vistas adecuadas para res.country.state.
         Solo necesitamos la acción con dominio para Cuba. -->
    <record id="res_country_state_action" model="ir.actions.act_window">
        <field name="name">Provincias</field>
        <field name="res_model">res.country.state</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('country_id.code', '=', 'CU')]</field>
        <field name="context">{'default_country_id': %(base.cu)d}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear una nueva provincia
            </p>
            <p>
                Defina las provincias de Cuba disponibles en el sistema.
            </p>
        </field>
    </record>

</odoo>
