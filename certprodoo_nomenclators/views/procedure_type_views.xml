<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Vista Lista ──────────────────────────────────────── -->
    <record id="procedure_type_view_tree" model="ir.ui.view">
        <field name="name">certprodoo.procedure.type.tree</field>
        <field name="model">certprodoo.procedure.type</field>
        <field name="arch" type="xml">
            <tree string="Tipos de Trámite" decoration-muted="active == False">
                <field name="code"/>
                <field name="name"/>
                <field name="model_ref"/>
                <field name="document_count" string="Documentos"/>
                <field name="active" column_invisible="True"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- ─── Vista Formulario ─────────────────────────────────── -->
    <record id="procedure_type_view_form" model="ir.ui.view">
        <field name="name">certprodoo.procedure.type.form</field>
        <field name="model">certprodoo.procedure.type</field>
        <field name="arch" type="xml">
            <form string="Tipo de Trámite">
                <header>
                    <button name="toggle_active" type="object"
                            string="Archivar" class="btn-secondary"
                            invisible="active == False"
                            groups="certprodoo_nomenclators.group_nomenclator_manager"/>
                    <button name="toggle_active" type="object"
                            string="Desarchivar" class="btn-secondary"
                            invisible="active == True"
                            groups="certprodoo_nomenclators.group_nomenclator_manager"/>
                </header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_documents" type="object"
                                class="oe_stat_button" icon="fa-file-text-o">
                            <field name="document_count" string="Documentos" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nombre del tipo de trámite"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="model_ref" placeholder="ej. certprodoo.inscription"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Documentos Requeridos" name="documents">
                            <field name="document_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="is_document_required"/>
                                    <field name="is_personal_document"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ─── Acción ───────────────────────────────────────────── -->
    <record id="procedure_type_action" model="ir.actions.act_window">
        <field name="name">Tipos de Trámite</field>
        <field name="res_model">certprodoo.procedure.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo tipo de trámite
            </p>
            <p>
                Defina los tipos de trámite disponibles en el sistema de registro profesional.
            </p>
        </field>
    </record>

</odoo>
