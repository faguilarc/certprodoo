<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Vista Lista ──────────────────────────────────────── -->
    <record id="specialty_view_tree" model="ir.ui.view">
        <field name="name">certprodoo.specialty.tree</field>
        <field name="model">certprodoo.specialty</field>
        <field name="arch" type="xml">
            <tree string="Especialidades">
                <field name="name"/>
                <field name="profession_id"/>
                <field name="description"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- ─── Vista Búsqueda ───────────────────────────────────── -->
    <record id="specialty_view_search" model="ir.ui.view">
        <field name="name">certprodoo.specialty.search</field>
        <field name="model">certprodoo.specialty</field>
        <field name="arch" type="xml">
            <search string="Buscar Especialidades">
                <field name="name"/>
                <field name="profession_id"/>
                <field name="description" search="False"/>
                <group expand="0" string="Agrupar por">
                    <filter name="groupby_profession" string="Profesión"
                            context="{'group_by': 'profession_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Vista Formulario ─────────────────────────────────── -->
    <record id="specialty_view_form" model="ir.ui.view">
        <field name="name">certprodoo.specialty.form</field>
        <field name="model">certprodoo.specialty</field>
        <field name="arch" type="xml">
            <form string="Especialidad">
                <header>
                    <button name="toggle_active" type="object"
                            string="Archivar" class="btn-secondary"
                            invisible="active == False"
                            groups="certprodoo_nomenclators.group_nomenclator_manager"/>
                    <button name="toggle_active" type="object"
                            string="Desarchivar" class="btn-secondary"
                            invisible="active == True"
                            groups="certprodoo_nomenclators.group_nomenclator_manager"/>
                </header>
                <sheet>
                    <field name="active" invisible="1"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nombre de la especialidad"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="profession_id" options="{'no_create': True}"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="description" placeholder="Descripción de la especialidad"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ─── Acción ───────────────────────────────────────────── -->
    <record id="specialty_action" model="ir.actions.act_window">
        <field name="name">Especialidades</field>
        <field name="res_model">certprodoo.specialty</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear una nueva especialidad
            </p>
            <p>
                Defina las especialidades asociadas a las profesiones del sistema.
            </p>
        </field>
    </record>

</odoo>
