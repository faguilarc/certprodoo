<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Vista Lista ──────────────────────────────────────── -->
    <record id="city_view_tree" model="ir.ui.view">
        <field name="name">certprodoo.city.tree</field>
        <field name="model">certprodoo.city</field>
        <field name="arch" type="xml">
            <tree string="Municipios">
                <field name="code"/>
                <field name="name"/>
                <field name="state_id"/>
                <field name="country_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- ─── Vista Búsqueda ───────────────────────────────────── -->
    <record id="city_view_search" model="ir.ui.view">
        <field name="name">certprodoo.city.search</field>
        <field name="model">certprodoo.city</field>
        <field name="arch" type="xml">
            <search string="Buscar Municipios">
                <field name="name"/>
                <field name="state_id"/>
                <field name="code" search="False"/>
                <group expand="0" string="Agrupar por">
                    <filter name="groupby_state" string="Provincia"
                            context="{'group_by': 'state_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Vista Formulario ─────────────────────────────────── -->
    <record id="city_view_form" model="ir.ui.view">
        <field name="name">certprodoo.city.form</field>
        <field name="model">certprodoo.city</field>
        <field name="arch" type="xml">
            <form string="Municipio">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nombre del municipio"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="state_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="country_id" options="{'no_create': True}"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ─── Acción Municipios ────────────────────────────────── -->
    <record id="city_action" model="ir.actions.act_window">
        <field name="name">Municipios</field>
        <field name="res_model">certprodoo.city</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo municipio
            </p>
            <p>
                Defina los municipios disponibles en el sistema.
            </p>
        </field>
    </record>

</odoo>
