    <template id="professional_public_details" name="Professional Public Details">
        <t t-call="website.layout">
            <t t-call-assets="website_aicros.assets_register_user_form"/>

            <div class="container mt-5">
                <div class="card shadow-sm border-0 rounded-lg">
                    <div class="card-header bg-primary text-white">
                        <h3 class="mb-0">Detalles del Profesional</h3>
                    </div>

                    <div class="card-body">
                        <!-- Foto y nombre -->
                        <!-- Foto y nombre principal -->
                        <div class="row mb-4">
                            <div class="col-md-3">
                                <img t-if="'image' in visible_fields.get('personal', []) and professional.image"
                                     t-att-src="image_data_uri(professional.image)"
                                     class="img-fluid rounded"
                                     style="width: 200px; height: 200px; object-fit: cover;"/>
                            </div>
                            <div class="col-md-9">
                                <h2 t-if="all(field in visible_fields.get('personal', []) for field in ['name', 'first_last_name', 'second_last_name']) and professional.full_name"
                                    t-field="professional.full_name"/>
                                <p class="text-muted"
                                   t-if="all(field in visible_fields.get('personal', []) for field in ['name', 'first_last_name', 'second_last_name','image']) and professional.request_number">
                                    No. Registro:
                                    <span t-field="professional.request_number"/>
                                </p>
                            </div>
                        </div>


                        <!-- Datos Personales -->
                        <t t-if="visible_fields.get('personal')">
                            <div class="card mb-4 border-light shadow-sm">
                                <div class="card-header bg-light d-flex align-items-center">
                                    <i class="fa fa-user mr-2 text-primary"></i>
                                    <h5 class="mb-0">Datos Personales</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'name' in visible_fields['personal']">
                                                    <strong>Nombre</strong>
                                                    <span t-field="professional.name"/>
                                                </li>

                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'identity' in visible_fields['personal']">
                                                    <strong>CI/Pasaporte</strong>
                                                    <span t-field="professional.identity"/>
                                                </li>
                                            </ul>
                                        </div>
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'first_last_name' in visible_fields['personal']">
                                                    <strong>Primer Apellido</strong>
                                                    <span t-field="professional.first_last_name"/>
                                                </li>
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'nationality_id' in visible_fields['personal']">
                                                    <strong>Nacionalidad</strong>
                                                    <span t-field="professional.nationality_id"/>
                                                </li>

                                            </ul>
                                        </div>
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'second_last_name' in visible_fields['personal']">
                                                    <strong>Segundo Apellido</strong>
                                                    <span t-field="professional.second_last_name"/>
                                                </li>
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'sex' in visible_fields['personal']">
                                                    <strong>Sexo</strong>
                                                    <span t-field="professional.sex"/>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>


                        <!-- Datos de Contacto -->
                        <t t-if="visible_fields.get('contact')">
                            <div class="card mb-4 border-light shadow-sm">
                                <div class="card-header bg-light d-flex align-items-center">
                                    <i class="fa fa-phone mr-2 text-primary"></i>
                                    <h5 class="mb-0">Datos de Contacto</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'address' in visible_fields['contact']">
                                                    <strong>Dirección</strong>
                                                    <span t-field="professional.address"/>
                                                </li>
                                            </ul>
                                        </div>
                                        <div class="col-md-6">
                                            <ul class="list-group list-group-flush">

                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'email' in visible_fields['contact']">
                                                    <strong>Email</strong>
                                                    <span t-field="professional.email"/>
                                                </li>

                                            </ul>
                                        </div>
                                        <div class="col-md-6">
                                            <ul class="list-group list-group-flush">

                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'phone' in visible_fields['contact']">
                                                    <strong>Teléfono</strong>
                                                    <span t-field="professional.phone"/>
                                                </li>
                                            </ul>
                                        </div>
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'country' in visible_fields['contact']">
                                                    <strong>País</strong>
                                                    <span t-field="professional.country"/>
                                                </li>
                                            </ul>
                                        </div>
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">

                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'country_states' in visible_fields['contact']">
                                                    <strong>Provincia</strong>
                                                    <span t-field="professional.country_states"/>
                                                </li>

                                            </ul>
                                        </div>
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'city' in visible_fields['contact']">
                                                    <strong>Municipio</strong>
                                                    <span t-field="professional.city"/>
                                                </li>
                                            </ul>
                                        </div>


                                    </div>
                                </div>
                            </div>
                        </t>

                        <!-- Datos Académicos -->
                        <t t-if="visible_fields.get('academic')">
                            <div class="card mb-4 border-light shadow-sm">
                                <div class="card-header bg-light d-flex align-items-center">
                                    <i class="fa fa-book mr-2 text-primary"></i>
                                    <h5 class="mb-0">Datos Académicos</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'teaching_level' in visible_fields['academic']">
                                                    <strong>Nivel de Enseñanza</strong>
                                                    <span t-field="professional.teaching_level"/>
                                                </li>
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'volume' in visible_fields['academic']">
                                                    <strong>Tomo</strong>
                                                    <span t-field="professional.volume"/>
                                                </li>

                                            </ul>
                                        </div>
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'study_center' in visible_fields['academic']">
                                                    <strong>Centro de Estudios</strong>
                                                    <span t-field="professional.study_center"/>
                                                </li>

                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'folio' in visible_fields['academic']">
                                                    <strong>Folio</strong>
                                                    <span t-field="professional.folio"/>
                                                </li>

                                            </ul>
                                        </div>
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'degree_date' in visible_fields['academic']">
                                                    <strong>Fecha de Graduación</strong>
                                                    <span t-field="professional.degree_date"/>
                                                </li>
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'number' in visible_fields['academic']">
                                                    <strong>Número</strong>
                                                    <span t-field="professional.number"/>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>

                        <!-- Datos Profesionales -->
                        <t t-if="visible_fields.get('professional')">
                            <div class="card mb-4 border-light shadow-sm">
                                <div class="card-header bg-light d-flex align-items-center">
                                    <i class="fa fa-briefcase mr-2 text-primary"></i>
                                    <h5 class="mb-0">Datos Profesionales</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'profession' in visible_fields['professional']">
                                                    <strong>Profesión</strong>
                                                    <span t-field="professional.profession"/>
                                                </li>
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'specialties' in visible_fields['professional']">
                                                    <strong>Especialidad</strong>
                                                    <span t-field="professional.specialties"/>
                                                </li>
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'unaicc_date' in visible_fields['professional']">
                                                    <strong>Fecha UNAICC</strong>
                                                    <span t-field="professional.unaicc_date"/>
                                                </li>

                                            </ul>
                                        </div>
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">

                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'degree_sciences' in visible_fields['professional']">
                                                    <strong>Categoría Científica</strong>
                                                    <span t-field="professional.degree_sciences"/>
                                                </li>
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'degree_sciences_year' in visible_fields['professional']">
                                                    <strong>Año Cat. Científica</strong>
                                                    <span t-field="professional.degree_sciences_year"/>
                                                </li>
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'investigations_year' in visible_fields['professional']">
                                                    <strong>Investigaciones</strong>
                                                    <span t-field="professional.investigations_year"/>
                                                </li>
                                            </ul>
                                        </div>
                                        <div class="col-md-4">
                                            <ul class="list-group list-group-flush">
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'teaching_category' in visible_fields['professional']">
                                                    <strong>Categoría Docente</strong>
                                                    <span t-field="professional.teaching_category"/>
                                                </li>
                                                <li class="list-group-item d-flex justify-content-between align-items-center"
                                                    t-if="'teaching_category_date' in visible_fields['professional']">
                                                    <strong>Fecha Cat. Docente</strong>
                                                    <span t-field="professional.teaching_category_date"/>
                                                </li>
                                            </ul>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </t>

                        <!-- Trayectoria Laboral -->
                        <t t-if="visible_fields['work']">
                            <div class="card mb-4 border-light shadow-sm">
                                <div class="card-header bg-light d-flex align-items-center">
                                    <i class="fa fa-suitcase mr-2 text-primary"></i>
                                    <h5 class="mb-0">Vínculo Laboral</h5>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-hover table-bordered">
                                            <thead class="thead-light">
                                                <tr>
                                                    <th>Centro de Trabajo</th>
                                                    <th>Organismo</th>
                                                    <th>Entidad</th>
                                                    <th>Actividad</th>
                                                    <th>Teléfono</th>
                                                    <th>Desde</th>
                                                    <th>Hasta</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr t-foreach="professional.history_work" t-as="work">
                                                    <td>
                                                        <span t-field="work.work_center"/>
                                                    </td>
                                                    <td>
                                                        <span t-field="work.organism"/>
                                                    </td>
                                                    <td>
                                                        <span t-field="work.labour_sector"/>
                                                    </td>
                                                    <td>
                                                        <span t-field="work.activity"/>
                                                    </td>
                                                    <td>
                                                        <span t-field="work.phone"/>
                                                    </td>
                                                    <td>
                                                        <span t-field="work.date_from"/>
                                                    </td>
                                                    <td>
                                                        <span t-field="work.date_to"/>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </t>

                        <!-- Idiomas -->
                        <t t-if="visible_fields['language']">
                            <div class="card mb-4 border-light shadow-sm">
                                <div class="card-header bg-light d-flex align-items-center">
                                    <i class="fa fa-language mr-2 text-primary"></i>
                                    <h5 class="mb-0">Idiomas</h5>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-striped table-bordered">
                                            <thead class="thead-light">
                                                <tr>
                                                    <th>Idioma</th>
                                                    <th>Nivel</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr t-foreach="professional.professional_language" t-as="langaux">
                                                    <td>
                                                        <span t-field="langaux.language.name"/>
                                                    </td>
                                                    <td>
                                                        <span t-field="langaux.proficiency_level"/>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </t>

                        <!-- Documentos Requeridos -->
                        <div class="row mb-4" t-if="public_documents">
                            <div class="col-12">
                                <h4 class="border-bottom pb-2">Documentos Requeridos</h4>
                            </div>
                            <div class="col-md-12">
                                <div class="list-group">
                                    <t t-foreach="public_documents" t-as="doc">
                                        <a t-att-href="'/web/content/%s?download=true' % doc.id"
                                           t-att-title="'Descargar ' + doc.name"
                                           class="list-group-item list-group-item-action d-flex align-items-center"
                                           target="_blank"
                                           t-if="doc.datas">
                                            <i class="fa fa-file-pdf-o text-danger fa-lg mr-3"></i>
                                            <span t-esc="doc.name"/>
                                        </a>
                                    </t>
                                    <p t-if="not public_documents or not any(doc.datas for doc in public_documents)"
                                       class="text-muted mt-2">
                                        No hay documentos disponibles para descargar.
                                    </p>
                                </div>
                            </div>
                        </div>


                    </div>
                </div>

                <!-- Botón de Volver -->
                <div class="text-center mt-4 py-3  rounded">
                    <a href="/home"
                       class="btn btn-primary btn-lg px-4 shadow-sm">
                        <i class="fa fa-arrow-left mr-1"></i>
                        Volver
                    </a>
                </div>
            </div>
        </t>
    </template>

    <template id="professional_not_available" name="Professional Not Available">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure">
                <div class="container mt-5">
                    <div class="alert alert-warning text-center">
                        <h3 t-esc="message"/>
                        <p>Contacte al profesional para solicitar acceso</p>
                    </div>
                </div>

                <div class="text-center mt-4 py-3  rounded">
                    <a href="/home"
                       class="btn btn-primary btn-lg px-4 shadow-sm">
                        <i class="fa fa-arrow-left mr-1"></i>
                        Volver
                    </a>
                </div>
            </div>
        </t>
    </template>
</odoo>