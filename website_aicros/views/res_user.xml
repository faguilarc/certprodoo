<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="users_inherit" model="ir.ui.view">
            <field name="name">Usuarios</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/><!--user_groups_view-->
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//label[@for='login']" position="before">
                    <group class="row">
                        <group class="col-lg-4">
                            <field name="first_last_name" required="1" string="Primer Apellido"/>
                        </group>
                        <group class="col-lg-4">
                            <field name="second_last_name" required="1" string="Segundo Apellido"/>
                        </group>
                        <group class="col-lg-4">
                            <field name="full_name" required="1" string="Nombre y apellidos"/>
                        </group>
                        <group class="col-lg-4">
                            <field name="identification" required="1" string="CI o Pasaporte"/>
                        </group>
                    </group>
                    <group>
                        <field name="nationality_id" required="1" string="Nacionalidad" class="w-25"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>